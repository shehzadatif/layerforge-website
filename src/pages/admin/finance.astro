---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import {
  formatPacificDateTime,
  PACIFIC_TIME_ZONE,
} from "../../lib/dateUtils";

const { data: orderRows, error } = await supabaseAdmin
  .from("orders")
  .select(`
    id,
    order_number,
    customer_name,
    email,
    subtotal,
    shipping,
    tax,
    total,
    payment_status,
    order_status,
    created_at
  `)
  .eq("payment_status", "Paid")
  .order("created_at", { ascending: false });

if (error) {
  console.error("Unable to load finance data:", error);
}

const paidOrders = orderRows ?? [];

const currency = new Intl.NumberFormat("en-CA", {
  style: "currency",
  currency: "CAD",
  minimumFractionDigits: 2,
});

const pacificPartsFormatter = new Intl.DateTimeFormat("en-CA", {
  timeZone: PACIFIC_TIME_ZONE,
  year: "numeric",
  month: "2-digit",
});

function getMonthKey(value: string | Date) {
  const parts = pacificPartsFormatter.formatToParts(new Date(value));
  const year = parts.find((part) => part.type === "year")?.value;
  const month = parts.find((part) => part.type === "month")?.value;
  return `${year}-${month}`;
}

const currentMonthKey = getMonthKey(new Date());
const currentYear = currentMonthKey.slice(0, 4);

const amount = (value: unknown) => {
  const parsed = Number(value ?? 0);
  return Number.isFinite(parsed) ? parsed : 0;
};

const totalRevenue = paidOrders.reduce(
  (sum, order) => sum + amount(order.total),
  0,
);
const productRevenue = paidOrders.reduce(
  (sum, order) => sum + amount(order.subtotal),
  0,
);
const taxCollected = paidOrders.reduce(
  (sum, order) => sum + amount(order.tax),
  0,
);
const shippingCollected = paidOrders.reduce(
  (sum, order) => sum + amount(order.shipping),
  0,
);
const thisMonthRevenue = paidOrders
  .filter((order) => getMonthKey(order.created_at) === currentMonthKey)
  .reduce((sum, order) => sum + amount(order.total), 0);
const thisYearRevenue = paidOrders
  .filter((order) => getMonthKey(order.created_at).startsWith(currentYear))
  .reduce((sum, order) => sum + amount(order.total), 0);
const averageOrderValue = paidOrders.length
  ? totalRevenue / paidOrders.length
  : 0;

const monthlyTotals = new Map<string, { revenue: number; orders: number }>();
for (const order of paidOrders) {
  const key = getMonthKey(order.created_at);
  const existing = monthlyTotals.get(key) ?? { revenue: 0, orders: 0 };
  existing.revenue += amount(order.total);
  existing.orders += 1;
  monthlyTotals.set(key, existing);
}

const nowParts = currentMonthKey.split("-").map(Number);
const monthlyRevenue = Array.from({ length: 12 }, (_, index) => {
  const date = new Date(
    Date.UTC(nowParts[0], nowParts[1] - 1 - (11 - index), 1),
  );
  const key = date.toISOString().slice(0, 7);
  const values = monthlyTotals.get(key) ?? { revenue: 0, orders: 0 };
  return {
    key,
    label: new Intl.DateTimeFormat("en-CA", {
      month: "short",
      year: "2-digit",
      timeZone: "UTC",
    }).format(date),
    ...values,
  };
});

const maxMonthlyRevenue = Math.max(
  ...monthlyRevenue.map((month) => month.revenue),
  1,
);
const recentPayments = paidOrders.slice(0, 10);
---

<AdminLayout title="Finance | Layer Forge Admin" active="finance">
  <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-yellow-600">
        Financial overview
      </p>
      <h1 class="mt-2 text-4xl font-bold text-slate-900">Finance</h1>
      <p class="mt-2 text-slate-500">
        Income recorded from paid customer orders. All dates use Pacific Time.
      </p>
    </div>
    <a
      href="/admin/orders"
      class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-5 py-3 font-semibold text-slate-800 transition hover:border-yellow-400"
    >
      View all orders
    </a>
  </div>

  {
    error ? (
      <div class="mb-8 rounded-2xl border border-red-200 bg-red-50 p-5 text-red-800">
        Finance data could not be loaded. Please refresh the page or try again later.
      </div>
    ) : null
  }

  <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
    <article class="rounded-2xl bg-slate-950 p-6 text-white shadow-sm">
      <p class="text-sm font-medium text-slate-400">Total paid revenue</p>
      <p class="mt-3 text-3xl font-bold text-yellow-400">
        {currency.format(totalRevenue)}
      </p>
      <p class="mt-3 text-sm text-slate-400">Across {paidOrders.length} paid orders</p>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Revenue this month</p>
      <p class="mt-3 text-3xl font-bold text-slate-950">
        {currency.format(thisMonthRevenue)}
      </p>
      <p class="mt-3 text-sm text-slate-500">Current Pacific calendar month</p>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Revenue this year</p>
      <p class="mt-3 text-3xl font-bold text-slate-950">
        {currency.format(thisYearRevenue)}
      </p>
      <p class="mt-3 text-sm text-slate-500">Paid orders in {currentYear}</p>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Average order value</p>
      <p class="mt-3 text-3xl font-bold text-slate-950">
        {currency.format(averageOrderValue)}
      </p>
      <p class="mt-3 text-sm text-slate-500">Average final amount paid</p>
    </article>
  </div>

  <div class="mt-8 grid gap-8 xl:grid-cols-[1.6fr_0.8fr]">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <div>
        <h2 class="text-2xl font-bold text-slate-950">Revenue by month</h2>
        <p class="mt-1 text-sm text-slate-500">Last 12 months of paid order income</p>
      </div>

      <div class="mt-8 overflow-x-auto pb-2">
        <div class="flex h-72 min-w-[720px] items-end gap-3 border-b border-slate-200 px-2">
          {
            monthlyRevenue.map((month) => {
              const height = month.revenue
                ? Math.max((month.revenue / maxMonthlyRevenue) * 100, 5)
                : 1;

              return (
                <div class="flex h-full flex-1 flex-col justify-end text-center">
                  <div class="mb-2 text-xs font-semibold text-slate-700">
                    {month.revenue ? currency.format(month.revenue) : "—"}
                  </div>
                  <div class="flex h-52 items-end justify-center">
                    <div
                      class="w-full max-w-12 rounded-t-lg bg-yellow-400 transition hover:bg-yellow-300"
                      style={`height: ${height}%`}
                      title={`${month.label}: ${currency.format(month.revenue)} from ${month.orders} orders`}
                    ></div>
                  </div>
                  <div class="mt-3 whitespace-nowrap text-xs font-medium text-slate-500">
                    {month.label}
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-2xl font-bold text-slate-950">Revenue breakdown</h2>
      <p class="mt-1 text-sm text-slate-500">All-time paid order totals</p>

      <dl class="mt-8 space-y-5">
        <div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-5">
          <dt class="text-slate-600">Products & services</dt>
          <dd class="font-bold text-slate-950">{currency.format(productRevenue)}</dd>
        </div>
        <div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-5">
          <dt class="text-slate-600">Shipping collected</dt>
          <dd class="font-bold text-slate-950">{currency.format(shippingCollected)}</dd>
        </div>
        <div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-5">
          <dt class="text-slate-600">Tax collected</dt>
          <dd class="font-bold text-slate-950">{currency.format(taxCollected)}</dd>
        </div>
        <div class="flex items-center justify-between gap-4 pt-1">
          <dt class="font-bold text-slate-950">Total received</dt>
          <dd class="text-xl font-bold text-green-700">{currency.format(totalRevenue)}</dd>
        </div>
      </dl>

      <p class="mt-8 rounded-xl bg-slate-50 p-4 text-sm leading-6 text-slate-500">
        This page reports gross income received. Stripe fees, material costs,
        refunds, and other business expenses are not deducted.
      </p>
    </section>
  </div>

  <section class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-slate-950">Recent payments</h2>
      <p class="mt-1 text-sm text-slate-500">The latest orders marked as paid</p>
    </div>

    {
      recentPayments.length ? (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-600">Order</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-600">Customer</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-slate-600">Order date</th>
                <th class="px-6 py-4 text-right text-sm font-semibold text-slate-600">Amount</th>
                <th class="px-6 py-4"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {recentPayments.map((order) => (
                <tr class="hover:bg-slate-50">
                  <td class="whitespace-nowrap px-6 py-5 font-bold text-slate-950">
                    LF{String(order.order_number).padStart(6, "0")}
                  </td>
                  <td class="px-6 py-5">
                    <div class="font-semibold text-slate-900">{order.customer_name}</div>
                    <div class="text-sm text-slate-500">{order.email}</div>
                  </td>
                  <td class="whitespace-nowrap px-6 py-5 text-sm text-slate-600">
                    {formatPacificDateTime(order.created_at)}
                  </td>
                  <td class="whitespace-nowrap px-6 py-5 text-right font-bold text-green-700">
                    {currency.format(amount(order.total))}
                  </td>
                  <td class="px-6 py-5 text-right">
                    <a href={`/admin/orders/${order.id}`} class="font-semibold text-blue-700 hover:underline">
                      View
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="p-10 text-center text-slate-500">
          No paid orders have been recorded yet.
        </div>
      )
    }
  </section>
</AdminLayout>
