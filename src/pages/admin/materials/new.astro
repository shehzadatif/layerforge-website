---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Add Material" active="materials">

<div class="mx-auto max-w-3xl">

  <div class="mb-8">
    <h1 class="text-4xl font-bold">
      Add Material
    </h1>

    <p class="mt-2 text-slate-500">
      Create a new manufacturing material.
    </p>
  </div>

  <form
    action="/api/admin/materials"
    method="POST"
    class="space-y-6 rounded-2xl bg-white p-8 shadow"
  >

    <div>
      <label class="mb-2 block font-semibold">
        Material Name
      </label>

      <input
        type="text"
        name="name"
        required
        class="w-full rounded-lg border p-3"
      />
    </div>

    <button
      type="submit"
      class="rounded-lg bg-yellow-400 px-8 py-3 font-semibold hover:bg-yellow-300"
    >
      Save Material
    </button>

  </form>

</div>

</AdminLayout>