---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import StatCard from "../../components/admin/StatCard.astro";

const { data: quotes } = await supabaseAdmin
  .from("quotes")
  .select("*")
  .order("created_at", { ascending: false })
  .limit(10);

const { count: totalQuotes } = await supabaseAdmin
  .from("quotes")
  .select("*", { count: "exact", head: true });

const { count: newQuotes } = await supabaseAdmin
  .from("quotes")
  .select("*", { count: "exact", head: true })
  .eq("status", "New");

const { count: quotedQuotes } = await supabaseAdmin
  .from("quotes")
  .select("*", { count: "exact", head: true })
  .eq("status", "Quoted");

const { count: completedQuotes } = await supabaseAdmin
  .from("quotes")
  .select("*", { count: "exact", head: true })
  .eq("status", "Completed");
---

<AdminLayout title="Dashboard">

<h1 class="mb-8 text-4xl font-bold text-slate-900">
  Dashboard
</h1>

<!-- Stats -->

<div class="mb-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">

    <StatCard
        title="New Quotes"
        value={newQuotes ?? 0}
        color="text-yellow-500"
    />

    <StatCard
        title="Quoted"
        value={quotedQuotes ?? 0}
        color="text-blue-600"
    />

    <StatCard
        title="Completed"
        value={completedQuotes ?? 0}
        color="text-green-600"
    />

    <StatCard
        title="Total Quotes"
        value={totalQuotes ?? 0}
    />

</div>

<!-- Recent Quotes -->

<div class="rounded-2xl bg-white shadow">

  <div class="border-b p-6">

    <h2 class="text-2xl font-bold">
      Recent Quotes
    </h2>

  </div>

  <table class="w-full">

    <thead class="bg-slate-100">

      <tr>

        <th class="px-6 py-4 text-left">Customer</th>
        <th class="px-6 py-4 text-left">Service</th>
        <th class="px-6 py-4 text-left">Status</th>
        <th class="px-6 py-4 text-left">Action</th>

      </tr>

    </thead>

    <tbody>

      {quotes?.map((quote) => (

        <tr class="border-b hover:bg-slate-50">

          <td class="px-6 py-4">

            <div class="font-semibold">
              {quote.name}
            </div>

            <div class="text-sm text-slate-500">
              {quote.email}
            </div>

          </td>

          <td class="px-6 py-4">

            {quote.service}

          </td>

          <td class="px-6 py-4">

            <span class="rounded-full bg-yellow-100 px-3 py-1 text-sm font-semibold text-yellow-700">

              {quote.status}

            </span>

          </td>

          <td class="px-6 py-4">

            <a
              href={`/admin/quote/${quote.id}`}
              class="font-semibold text-blue-600 hover:underline"
            >
              View
            </a>

          </td>

        </tr>

      ))}

    </tbody>

  </table>

</div>

</AdminLayout>