---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Products | Layer Forge">

<section class="min-h-screen bg-slate-100">

  <div class="mx-auto max-w-7xl px-6 py-16">

    <div class="flex items-center justify-between">

      <div>

        <h1 class="text-5xl font-bold text-slate-900">
          Products
        </h1>

        <p class="mt-2 text-slate-600">
          Manage your online product catalog.
        </p>

      </div>

      <a
        href="/admin/products/new"
        class="rounded-xl bg-yellow-400 px-6 py-3 font-semibold text-slate-900 hover:bg-yellow-300"
      >
        + Add Product
      </a>

    </div>

    <div class="mt-12 overflow-hidden rounded-2xl bg-white shadow">

      <table class="min-w-full">

        <thead class="bg-slate-900 text-white">

          <tr>

            <th class="px-6 py-4 text-left">Image</th>

            <th class="px-6 py-4 text-left">Product</th>

            <th class="px-6 py-4 text-left">Category</th>

            <th class="px-6 py-4 text-left">Price</th>

            <th class="px-6 py-4 text-left">Stock</th>

            <th class="px-6 py-4 text-center">Actions</th>

          </tr>

        </thead>

        <tbody>

          <tr class="border-b">

            <td class="px-6 py-4">
              —
            </td>

            <td class="px-6 py-4 font-semibold">
              No products yet
            </td>

            <td class="px-6 py-4">—</td>

            <td class="px-6 py-4">—</td>

            <td class="px-6 py-4">—</td>

            <td class="px-6 py-4 text-center">—</td>

          </tr>

        </tbody>

      </table>

    </div>

  </div>

</section>

</MainLayout>