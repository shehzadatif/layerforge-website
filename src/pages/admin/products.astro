---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";

const { data: products, error } = await supabaseAdmin
  .from("products")
  .select(`
    *,
    categories(name)
  `)
  .order("created_at", { ascending: false });
---

<AdminLayout
  title="Products"
  active="products"
>

<div class="mb-8 flex items-center justify-between">

  <div>
    <h1 class="text-4xl font-bold text-slate-900">
      Products
    </h1>

    <p class="mt-2 text-slate-500">
      Manage your product catalog.
    </p>
  </div>

  <a
    href="/admin/products/new"
    class="rounded-lg bg-yellow-400 px-6 py-3 font-semibold text-slate-900 hover:bg-yellow-300"
  >
    + Add Product
  </a>

</div>

<div class="overflow-hidden rounded-2xl bg-white shadow">

<table class="min-w-full">

<thead class="bg-slate-100">

<tr>

<th class="px-6 py-4 text-left">Product</th>

<th class="px-6 py-4 text-left">Category</th>

<th class="px-6 py-4 text-right">Price</th>

<th class="px-6 py-4 text-center">Stock</th>

<th class="px-6 py-4 text-center">Status</th>

<th class="px-6 py-4 text-center">Featured</th>

<th class="px-6 py-4 text-right">Action</th>

</tr>

</thead>

<tbody>

{products?.map((product) => (

<tr class="border-b hover:bg-slate-50">

<td class="px-6 py-4">

<div class="font-semibold">

{product.name}

</div>

<div class="text-sm text-slate-500">

{product.sku}

</div>

</td>

<td class="px-6 py-4">

{product.categories?.name ?? "-"}

</td>

<td class="px-6 py-4 text-right">

${Number(product.price ?? 0).toFixed(2)}

</td>

<td class="px-6 py-4 text-center">

{product.stock}

</td>

<td class="px-6 py-4 text-center">

{product.status}

</td>

<td class="px-6 py-4 text-center">

{product.featured ? "⭐" : "-"}

</td>

<td class="px-6 py-4 text-right">

  <div class="flex justify-end gap-2">

    <a
      href={`/admin/products/${product.id}`}
      class="rounded-lg bg-slate-900 px-4 py-2 text-white hover:bg-slate-700"
    >
      Edit
    </a>

    <button
      type="button"
      onclick={`deleteProduct('${product.id}', '${product.name.replace(/'/g, "\\'")}')`}
      class="rounded-lg bg-red-600 px-4 py-2 text-white hover:bg-red-700"
    >
      Delete
    </button>

  </div>

</td>

</tr>

))}

</tbody>

</table>

</div>

<script>
  window.deleteProduct = async function (
    productId,
    productName
  ) {
    const confirmed = confirm(
      `Delete "${productName}"?\n\nThis action cannot be undone.`
    );

    if (!confirmed) {
      return;
    }

    try {
      const response = await fetch(
        "/api/admin/delete-product",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            productId,
          }),
        }
      );

      const result = await response.json();

      if (!response.ok || !result.success) {
        alert(
          result.error ||
          "Unable to delete product."
        );

        return;
      }

      location.reload();
    } catch (error) {
      console.error(error);
      alert("Unable to delete product.");
    }
  };
</script>

</AdminLayout>