---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";

const { data, error } = await supabaseAdmin
  .from("settings")
  .select("setting_key, setting_value");

if (error) {
  console.error("Unable to load settings:", error);
}

const settingsMap = new Map(
  (data ?? []).map((row) => [
    row.setting_key,
    row.setting_value ?? "",
  ])
);

const getSetting = (
  key: string,
  fallback = ""
) => settingsMap.get(key) ?? fallback;

const stripeConnected = Boolean(
  import.meta.env.STRIPE_SECRET_KEY
);

const resendConnected = Boolean(
  import.meta.env.RESEND_API_KEY
);

const supabaseConnected = Boolean(
  import.meta.env.SUPABASE_URL &&
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);
---

<AdminLayout title="Settings" active="settings">

  <div class="mb-8">
    <h1 class="text-4xl font-bold">
      Settings
    </h1>

    <p class="mt-2 text-slate-500">
      Manage business details and application defaults.
    </p>
  </div>

  <form
    action="/api/admin/update-settings"
    method="POST"
    class="space-y-8"
  >

    <div class="rounded-2xl bg-white p-8 shadow">

      <h2 class="mb-6 text-2xl font-bold">
        Company Information
      </h2>

      <div class="grid gap-6 md:grid-cols-2">

        <div>
          <label class="mb-2 block font-semibold">
            Company Name
          </label>

          <input
            name="company_name"
            value={getSetting("company_name", "Layer Forge")}
            required
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Website
          </label>

          <input
            name="website"
            value={getSetting(
              "website",
              "https://layerforgecanada.com"
            )}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Phone
          </label>

          <input
            name="company_phone"
            value={getSetting("company_phone")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Support Email
          </label>

          <input
            type="email"
            name="support_email"
            value={getSetting("support_email")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div class="md:col-span-2">
          <label class="mb-2 block font-semibold">
            Address
          </label>

          <textarea
            name="company_address"
            rows="4"
            class="w-full rounded-xl border px-4 py-3"
          >{getSetting("company_address")}</textarea>
        </div>

      </div>
    </div>

    <div class="rounded-2xl bg-white p-8 shadow">

      <h2 class="mb-6 text-2xl font-bold">
        Email Settings
      </h2>

      <div class="grid gap-6 md:grid-cols-2">

        <div>
          <label class="mb-2 block font-semibold">
            Quote From Email
          </label>

          <input
            type="email"
            name="quote_from_email"
            value={getSetting("quote_from_email")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Order From Email
          </label>

          <input
            type="email"
            name="order_from_email"
            value={getSetting("order_from_email")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Reply-To Email
          </label>

          <input
            type="email"
            name="reply_to_email"
            value={getSetting("reply_to_email")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

      </div>
    </div>

    <div class="rounded-2xl bg-white p-8 shadow">

      <h2 class="mb-6 text-2xl font-bold">
        Business Defaults
      </h2>

      <div class="grid gap-6 md:grid-cols-2">

        <div>
          <label class="mb-2 block font-semibold">
            Tax Name
          </label>

          <input
            name="tax_name"
            value={getSetting("tax_name", "GST")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Default Tax Rate (%)
          </label>

          <input
            type="number"
            step="0.01"
            min="0"
            name="default_tax_rate"
            value={getSetting("default_tax_rate", "0")}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Production Lead Days
          </label>

          <input
            type="number"
            min="0"
            name="production_lead_days"
            value={getSetting(
              "production_lead_days",
              "5"
            )}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Shipping Lead Days
          </label>

          <input
            type="number"
            min="0"
            name="shipping_lead_days"
            value={getSetting(
              "shipping_lead_days",
              "3"
            )}
            class="w-full rounded-xl border px-4 py-3"
          />
        </div>

      </div>
    </div>

    <div class="rounded-2xl bg-white p-8 shadow">

      <h2 class="mb-6 text-2xl font-bold">
        Integrations
      </h2>

      <div class="grid gap-4 md:grid-cols-3">

        <div class="rounded-xl border p-5">
          <div class="font-semibold">
            Stripe
          </div>

          <div class={`mt-2 font-semibold ${
            stripeConnected
              ? "text-green-600"
              : "text-red-600"
          }`}>
            {stripeConnected ? "Connected" : "Missing"}
          </div>
        </div>

        <div class="rounded-xl border p-5">
          <div class="font-semibold">
            Resend
          </div>

          <div class={`mt-2 font-semibold ${
            resendConnected
              ? "text-green-600"
              : "text-red-600"
          }`}>
            {resendConnected ? "Connected" : "Missing"}
          </div>
        </div>

        <div class="rounded-xl border p-5">
          <div class="font-semibold">
            Supabase
          </div>

          <div class={`mt-2 font-semibold ${
            supabaseConnected
              ? "text-green-600"
              : "text-red-600"
          }`}>
            {supabaseConnected ? "Connected" : "Missing"}
          </div>
        </div>

      </div>
    </div>

    <button
      type="submit"
      class="rounded-xl bg-yellow-400 px-8 py-4 font-bold text-slate-950 hover:bg-yellow-300"
    >
      Save Settings
    </button>

  </form>

</AdminLayout>
