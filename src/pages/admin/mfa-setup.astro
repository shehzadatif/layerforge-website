---
const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

if (!user) {
  return Astro.redirect("/admin/login", 303);
}

const errorCode = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
  invalid_code:
    "The verification code was invalid or expired. Enter the current code from your authenticator app.",
  missing_code: "Enter the six-digit code from your authenticator app.",
  verification_failed:
    "The authenticator could not be verified. Please try again.",
};

let pageError = errorCode ? errorMessages[errorCode] : undefined;
let factorId = "";
let qrCode = "";
let secret = "";

const { data: factorsData, error: factorsError } =
  await supabase.auth.mfa.listFactors();

if (factorsError) {
  console.error("Unable to list MFA factors during enrollment.", {
    userId: user.id,
    error: factorsError,
  });

  pageError =
    "Authenticator setup is temporarily unavailable. Please try again.";
} else {
  /*
   * Remove stale, unverified TOTP enrollments. This prevents repeated page
   * refreshes from accumulating unusable factors on the account.
   */
  const unverifiedFactors = factorsData.all.filter(
    (factor) =>
      factor.factor_type === "totp" &&
      factor.status === "unverified",
  );

  for (const factor of unverifiedFactors) {
    const { error } = await supabase.auth.mfa.unenroll({
      factorId: factor.id,
    });

    if (error) {
      console.warn("Unable to remove stale MFA factor.", {
        userId: user.id,
        factorId: factor.id,
        error,
      });
    }
  }

  const { data: enrollment, error: enrollmentError } =
    await supabase.auth.mfa.enroll({
      factorType: "totp",
      friendlyName: "Layer Forge Admin",
    });

  if (enrollmentError) {
    console.error("Unable to enroll admin TOTP factor.", {
      userId: user.id,
      error: enrollmentError,
    });

    pageError =
      "Authenticator setup is temporarily unavailable. Please try again.";
  } else {
    factorId = enrollment.id;
    qrCode = enrollment.totp.qr_code;
    secret = enrollment.totp.secret;
  }
}

const enrollmentReady = Boolean(factorId && qrCode && secret);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <title>Set Up MFA | Layer Forge</title>
  </head>

  <body>
    <main class="auth-page">
      <section class="auth-card" aria-labelledby="mfa-heading">
        <header>
          <a class="brand" href="/" aria-label="Layer Forge home">
            <img
              src="/brand/logos/layer-forge-horizontal-reverse-transparent.png"
              alt="Layer Forge"
            />
          </a>

          <p class="eyebrow">Admin security</p>

          <h1 id="mfa-heading">Set up your authenticator</h1>

          <p class="description">
            Scan the QR code with an authenticator app, then enter the
            six-digit code it generates.
          </p>
        </header>

        {
          pageError && (
            <div class="alert" role="alert">
              {pageError}
            </div>
          )
        }

        {
          enrollmentReady && (
            <>
              <div class="qr-container">
                <img
                  src={qrCode}
                  width="220"
                  height="220"
                  alt="Layer Forge authenticator enrollment QR code"
                />
              </div>

              <section class="manual-setup">
                <h2>Manual setup key</h2>

                <p>
                  Enter this key manually if you cannot scan the QR code.
                </p>

                <code>{secret}</code>
              </section>

              <form
                method="POST"
                action="/api/auth/admin/mfa/verify-enrollment"
              >
                <input
                  type="hidden"
                  name="factorId"
                  value={factorId}
                />

                <div class="field">
                  <label for="code">
                    Six-digit verification code
                  </label>

                  <input
                    id="code"
                    name="code"
                    type="text"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    pattern="[0-9]{6}"
                    minlength="6"
                    maxlength="6"
                    placeholder="000000"
                    required
                    autofocus
                  />
                </div>

                <button type="submit">
                  Enable authenticator
                </button>
              </form>
            </>
          )
        }

        {
          !enrollmentReady && (
            <a class="retry-link" href="/admin/mfa-setup">
              Try again
            </a>
          )
        }

        <p class="security-note">
          Signed in as
          <strong>{user.email ?? "authorized administrator"}</strong>
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    min-width: 320px;
    background: #09090b;
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  :global(body) {
    min-height: 100vh;
    margin: 0;
  }

  .auth-page {
    display: grid;
    min-height: 100vh;
    place-items: center;
    padding: 2rem 1rem;
  }

  .auth-card {
    width: min(100%, 31rem);
    padding: 2rem;
    border: 1px solid #27272a;
    border-radius: 1rem;
    background: #18181b;
  }

  header {
    margin-bottom: 1.5rem;
  }

  .brand {
    display: inline-block;
    width: min(100%, 15rem);
    margin-bottom: 2rem;
    text-decoration: none;
  }

  .brand img {
    display: block;
    width: 100%;
    height: auto;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: #a1a1aa;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #fafafa;
    font-size: 2rem;
    letter-spacing: -0.04em;
  }

  .description {
    margin: 0.75rem 0 0;
    color: #a1a1aa;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .alert {
    margin-bottom: 1.25rem;
    padding: 0.875rem 1rem;
    border: 1px solid #7f1d1d;
    border-radius: 0.625rem;
    background: rgba(127, 29, 29, 0.22);
    color: #fecaca;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .qr-container {
    display: grid;
    place-items: center;
    margin-bottom: 1.25rem;
    padding: 1rem;
    border-radius: 0.75rem;
    background: #ffffff;
  }

  .qr-container img {
    display: block;
    width: min(100%, 13.75rem);
    height: auto;
  }

  .manual-setup {
    margin-bottom: 1.5rem;
    padding: 1rem;
    border: 1px solid #3f3f46;
    border-radius: 0.75rem;
    background: #09090b;
  }

  .manual-setup h2 {
    margin: 0;
    color: #e4e4e7;
    font-size: 0.875rem;
  }

  .manual-setup p {
    margin: 0.375rem 0 0.75rem;
    color: #a1a1aa;
    font-size: 0.8125rem;
  }

  code {
    display: block;
    overflow-wrap: anywhere;
    color: #fafafa;
    font-size: 0.8125rem;
    line-height: 1.5;
    user-select: all;
  }

  form {
    display: grid;
    gap: 1.25rem;
  }

  .field {
    display: grid;
    gap: 0.5rem;
  }

  label {
    color: #e4e4e7;
    font-size: 0.875rem;
    font-weight: 650;
  }

  input {
    width: 100%;
    min-height: 3rem;
    padding: 0.75rem;
    border: 1px solid #3f3f46;
    border-radius: 0.625rem;
    outline: none;
    background: #09090b;
    color: #fafafa;
    font: inherit;
    font-size: 1.25rem;
    letter-spacing: 0.3em;
    text-align: center;
  }

  input:focus {
    border-color: #a1a1aa;
    box-shadow: 0 0 0 3px rgba(161, 161, 170, 0.18);
  }

  button,
  .retry-link {
    display: grid;
    min-height: 2.875rem;
    place-items: center;
    padding: 0.75rem 1rem;
    border: 1px solid #fafafa;
    border-radius: 0.625rem;
    background: #fafafa;
    color: #18181b;
    font: inherit;
    font-weight: 750;
    text-align: center;
    text-decoration: none;
  }

  button {
    cursor: pointer;
  }

  .security-note {
    margin: 1.5rem 0 0;
    color: #71717a;
    font-size: 0.75rem;
    text-align: center;
  }

  .security-note strong {
    margin-left: 0.25rem;
    color: #a1a1aa;
  }
</style>
