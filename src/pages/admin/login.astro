---
const returnTo = Astro.url.searchParams.get("returnTo") ?? "/admin";
const errorCode = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
  invalid_credentials: "The email address or password is incorrect.",
  missing_credentials: "Enter both your email address and password.",
  auth_unavailable:
    "Authentication is temporarily unavailable. Please try again.",
  session_expired:
    "Your admin session expired after 2 hours of inactivity. Sign in again to continue.",
};

const errorMessage = errorCode ? errorMessages[errorCode] : undefined;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <title>Admin Login | Layer Forge</title>
  </head>

  <body>
    <main class="auth-page">
      <section class="auth-card" aria-labelledby="login-heading">
        <header class="auth-header">
          <a class="brand" href="/" aria-label="Layer Forge home">
            <img
              src="/brand/logos/layer-forge-horizontal-reverse-transparent.png"
              alt="Layer Forge"
            />
          </a>

          <p class="eyebrow">Secure administration</p>

          <h1 id="login-heading">Admin login</h1>

          <p class="description">
            Sign in with your authorized administrator account. Multi-factor
            authentication is required.
          </p>
        </header>

        {
          errorMessage && (
            <div class="alert" role="alert">
              {errorMessage}
            </div>
          )
        }

        <form method="POST" action="/api/auth/admin/login">
          <input type="hidden" name="returnTo" value={returnTo} />

          <div class="field">
            <label for="email">Email address</label>

            <input
              id="email"
              name="email"
              type="email"
              inputmode="email"
              autocomplete="username"
              autocapitalize="none"
              spellcheck="false"
              required
              autofocus
            />
          </div>

          <div class="field">
            <label for="password">Password</label>

            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
            />
          </div>

          <button type="submit">Continue securely</button>
        </form>

        <p class="security-note">
          Access is restricted to authorized personnel. Authentication activity
          may be logged.
        </p>
      </section>
    </main>

    <script is:inline>
      try {
        window.localStorage.removeItem(
          "layer-forge-admin-last-activity",
        );
      } catch {
        // Local storage may be unavailable in privacy mode.
      }
    </script>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    min-width: 320px;
    background: #09090b;
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  :global(body) {
    min-height: 100vh;
    margin: 0;
  }

  .auth-page {
    display: grid;
    min-height: 100vh;
    place-items: center;
    padding: 2rem 1rem;
    background:
      radial-gradient(
        circle at top,
        rgba(82, 82, 91, 0.22),
        transparent 38rem
      ),
      #09090b;
  }

  .auth-card {
    width: min(100%, 28rem);
    padding: clamp(1.5rem, 5vw, 2.5rem);
    border: 1px solid #27272a;
    border-radius: 1rem;
    background: rgba(24, 24, 27, 0.94);
    box-shadow: 0 1.5rem 5rem rgba(0, 0, 0, 0.35);
  }

  .auth-header {
    margin-bottom: 1.75rem;
  }

  .brand {
    display: inline-block;
    width: min(100%, 15rem);
    margin-bottom: 2rem;
    text-decoration: none;
  }

  .brand img {
    display: block;
    width: 100%;
    height: auto;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: #a1a1aa;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #fafafa;
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .description {
    margin: 0.875rem 0 0;
    color: #a1a1aa;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .alert {
    margin-bottom: 1.25rem;
    padding: 0.875rem 1rem;
    border: 1px solid #7f1d1d;
    border-radius: 0.625rem;
    background: rgba(127, 29, 29, 0.22);
    color: #fecaca;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  form {
    display: grid;
    gap: 1.25rem;
  }

  .field {
    display: grid;
    gap: 0.5rem;
  }

  label {
    color: #e4e4e7;
    font-size: 0.875rem;
    font-weight: 650;
  }

  input {
    width: 100%;
    min-height: 2.875rem;
    padding: 0.75rem 0.875rem;
    border: 1px solid #3f3f46;
    border-radius: 0.625rem;
    outline: none;
    background: #09090b;
    color: #fafafa;
    font: inherit;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease;
  }

  input:hover {
    border-color: #52525b;
  }

  input:focus {
    border-color: #a1a1aa;
    box-shadow: 0 0 0 3px rgba(161, 161, 170, 0.18);
  }

  button {
    min-height: 2.875rem;
    margin-top: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid #fafafa;
    border-radius: 0.625rem;
    background: #fafafa;
    color: #18181b;
    cursor: pointer;
    font: inherit;
    font-weight: 750;
    transition:
      background-color 150ms ease,
      border-color 150ms ease,
      transform 100ms ease;
  }

  button:hover {
    border-color: #d4d4d8;
    background: #d4d4d8;
  }

  button:active {
    transform: translateY(1px);
  }

  button:focus-visible,
  .brand:focus-visible {
    outline: 3px solid rgba(161, 161, 170, 0.6);
    outline-offset: 3px;
  }

  .security-note {
    margin: 1.5rem 0 0;
    color: #71717a;
    font-size: 0.75rem;
    line-height: 1.5;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    input,
    button {
      transition: none;
    }
  }
</style>
