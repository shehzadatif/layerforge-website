---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";
import { formatPacificDate } from "../../../lib/dateUtils";

const { data: quotes, error } = await supabaseAdmin
  .from("quotes")
  .select("*")
  .order("created_at", {
    ascending: false,
  });

if (error) {
  console.error("Unable to load quotes:", error);
}

const quoteList = quotes ?? [];
---

<AdminLayout title="Quotes" active="quotes">

  <div class="mb-8 flex items-center justify-between">

    <div>
      <h1 class="text-4xl font-bold">
        Quotes
      </h1>

      <p class="mt-2 text-slate-500">
        Manage customer quotations.
      </p>
    </div>

    <a
      href="/admin/quotes/new"
      class="rounded-xl bg-yellow-500 px-5 py-3 font-semibold text-slate-900 hover:bg-yellow-400"
    >
      + New Quote
    </a>

  </div>

  <div class="overflow-x-auto rounded-2xl bg-white shadow">

    <table class="min-w-full">

      <thead class="bg-slate-900 text-white">

        <tr>
          <th class="px-6 py-4 text-left">
            Quote
          </th>

          <th class="px-6 py-4 text-left">
            Customer
          </th>

          <th class="px-6 py-4 text-left">
            Project
          </th>

          <th class="px-6 py-4 text-left">
            Status
          </th>

          <th class="px-6 py-4 text-right">
            Total
          </th>

          <th class="px-6 py-4 text-left">
            Date
          </th>

          <th class="px-6 py-4"></th>
        </tr>

      </thead>

      <tbody>

        {
          quoteList.length > 0 ? (
            quoteList.map((quote: any) => {

              const quoteNumber = quote.quote_number
  ? String(quote.quote_number)
  : "Quote";

              const total = Number(
                quote.quoted_price ??
                quote.estimated_price ??
                0
              );

              return (
                <tr class="border-b hover:bg-slate-50">

                  <td class="px-6 py-5 font-semibold">
                    {quoteNumber}
                  </td>

                  <td class="px-6 py-5">

                    <div class="font-semibold">
                      {quote.name}
                    </div>

                    <div class="text-sm text-slate-500">
                      {quote.email}
                    </div>

                  </td>

                  <td class="px-6 py-5">
                    {quote.project_name || quote.service || "-"}
                  </td>

                  <td class="px-6 py-5">

                    <span
                      class={`rounded-full px-3 py-1 text-sm font-semibold ${
                        quote.status === "Approved"
                          ? "bg-green-100 text-green-700"
                          : quote.status === "Rejected"
                          ? "bg-red-100 text-red-700"
                          : quote.status === "Sent"
                          ? "bg-blue-100 text-blue-700"
                          : quote.status === "Converted"
                          ? "bg-emerald-100 text-emerald-700"
                          : "bg-yellow-100 text-yellow-700"
                      }`}
                    >
                      {quote.status}
                    </span>

                  </td>

                  <td class="px-6 py-5 text-right font-semibold">
                    CAD ${total.toFixed(2)}
                  </td>

                  <td class="px-6 py-5">
                    {formatPacificDate(quote.created_at)}
                  </td>

                  <td class="px-6 py-5 text-right">

                    <a
                      href={`/admin/quotes/${quote.id}`}
                      class="rounded-lg bg-yellow-400 px-4 py-2 font-semibold hover:bg-yellow-300"
                    >
                      View
                    </a>

                  </td>

                </tr>
              );
            })
          ) : (
            <tr>
              <td
                colspan="7"
                class="px-6 py-12 text-center text-slate-500"
              >
                No quotes found.
              </td>
            </tr>
          )
        }

      </tbody>

    </table>

  </div>

</AdminLayout>
