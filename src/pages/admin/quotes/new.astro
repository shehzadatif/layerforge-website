---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { data: products, error: productsError } =
  await supabaseAdmin
    .from("products")
    .select("id, name, price")
    .eq("status", "Active")
    .order("name");

if (productsError) {
  console.error("Unable to load products:", productsError);
}

const { data: materials, error: materialsError } =
  await supabaseAdmin
    .from("materials")
    .select("id, name")
    .order("name");

if (materialsError) {
  console.error("Unable to load materials:", materialsError);
}

const productList = products ?? [];
const materialList = materials ?? [];
---

<AdminLayout title="New Quote" active="quotes">

  <div class="mb-8 flex items-center justify-between">

    <div>
      <h1 class="text-4xl font-bold">
        New Quote
      </h1>

      <p class="mt-2 text-slate-500">
        Create a new customer quote.
      </p>
    </div>

    <a
      href="/admin/quotes"
      class="rounded-xl bg-slate-900 px-5 py-3 font-semibold text-white hover:bg-slate-700"
    >
      ← Back to Quotes
    </a>

  </div>

  <form
    action="/api/admin/create-quote"
    method="POST"
    class="space-y-8"
  >

    <div class="rounded-2xl bg-white p-8 shadow">

      <h2 class="mb-6 text-2xl font-bold">
        Customer
      </h2>

      <div class="grid gap-6 md:grid-cols-2">

        <div>
          <label class="mb-2 block font-semibold">
            Customer Name
          </label>

          <input
            name="customer_name"
            required
            class="w-full rounded-lg border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Email
          </label>

          <input
            type="email"
            name="email"
            required
            class="w-full rounded-lg border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Phone
          </label>

          <input
            name="phone"
            class="w-full rounded-lg border px-4 py-3"
          />
        </div>

      </div>

    </div>

    <div class="rounded-2xl bg-white p-8 shadow">

      <h2 class="mb-6 text-2xl font-bold">
        Quote Item
      </h2>

      <div class="grid gap-6 md:grid-cols-2">

        <div>
          <label for="service" class="mb-2 block font-semibold">
            Service
          </label>

          <select
            id="service"
            name="service"
            required
            class="w-full rounded-lg border px-4 py-3"
          >
            <option value="">Select a service</option>
            <option value="3D Printing">3D Printing</option>
            <option value="Laser Engraving">Laser Engraving</option>
            <option value="UV Printing">UV Printing</option>
            <option value="DTF & DTG">DTF & DTG</option>
            <option value="Other / Custom">Other / Custom</option>
          </select>

          <p class="mt-2 text-sm text-slate-500">
            Used to classify income in the Finance dashboard.
          </p>
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Product
          </label>

          <select
            id="productSelect"
            name="product_name"
            required
            class="w-full rounded-lg border px-4 py-3"
          >
            <option value="">
              Select a product
            </option>

           {
  productList.map((product: any) => (
    <option
      value={product.name}
      data-price={product.price ?? 0}
    >
      {product.name}
    </option>
  ))
}

          </select>
        </div>

   <div>
  <label class="mb-2 block font-semibold">
    Material
  </label>

  <select
    name="material"
    required
    class="w-full rounded-lg border px-4 py-3"
  >
    <option value="">
      Select a material
    </option>

    {
      materialList.map((material: any) => (
        <option value={material.name}>
          {material.name}
        </option>
      ))
    }
  </select>
</div>

        <div>
          <label class="mb-2 block font-semibold">
            Quantity
          </label>

          <input
            id="quantityInput"
            type="number"
            name="quantity"
            value="1"
            min="1"
            required
            class="w-full rounded-lg border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Unit Price
          </label>

          <input
            id="unitPriceInput"
            type="number"
            step="0.01"
            min="0"
            name="unit_price"
            required
            class="w-full rounded-lg border px-4 py-3"
          />
        </div>

        <div>
          <label class="mb-2 block font-semibold">
            Estimated Production Days
          </label>

          <input
            type="number"
            name="production_days"
            value="5"
            min="1"
            max="365"
            required
            class="w-full rounded-lg border px-4 py-3"
          />

          <p class="mt-2 text-sm text-slate-500">
            Business days after payment. The customer will see this estimate.
          </p>
        </div>

      </div>

      <div class="mt-6 rounded-xl bg-slate-50 p-5">

        <div class="flex items-center justify-between">

          <span class="font-semibold">
            Quote Total
          </span>

          <span
            id="quoteTotal"
            class="text-2xl font-bold"
          >
            CAD $0.00
          </span>

        </div>

      </div>

    </div>

    <div class="rounded-2xl bg-white p-8 shadow">

      <label class="mb-2 block font-semibold">
        Notes
      </label>

      <textarea
        name="notes"
        rows="6"
        class="w-full rounded-lg border px-4 py-3"
        placeholder="Project details, special instructions, production notes..."
      ></textarea>

    </div>

    <button
      type="submit"
      class="rounded-xl bg-yellow-400 px-8 py-4 font-bold text-slate-950 hover:bg-yellow-300"
    >
      Save Quote
    </button>

  </form>

  <script>
    const productSelect =
      document.getElementById("productSelect");

    const quantityInput =
      document.getElementById("quantityInput");

    const unitPriceInput =
      document.getElementById("unitPriceInput");

    const quoteTotal =
      document.getElementById("quoteTotal");

    function updateTotal() {
      const quantity =
        Number(quantityInput?.value ?? 0);

      const unitPrice =
        Number(unitPriceInput?.value ?? 0);

      const total = quantity * unitPrice;

      if (quoteTotal) {
        quoteTotal.textContent =
          `CAD $${total.toFixed(2)}`;
      }
    }

    productSelect?.addEventListener(
      "change",
      () => {
        const selectedOption =
          productSelect.options[
            productSelect.selectedIndex
          ];

        const price =
          Number(selectedOption.dataset.price ?? 0);

        if (unitPriceInput) {
          unitPriceInput.value =
            price.toFixed(2);
        }

        updateTotal();
      }
    );

    quantityInput?.addEventListener(
      "input",
      updateTotal
    );

    unitPriceInput?.addEventListener(
      "input",
      updateTotal
    );

    updateTotal();
  </script>

</AdminLayout>
