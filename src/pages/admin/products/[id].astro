---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;
const saved = Astro.url.searchParams.get("saved");

const { data: product } = await supabaseAdmin
  .from("products")
  .select(`
    *,
    categories(*),
    product_images(*)
  `)
  .eq("id", id)
  .single();

if (!product) {
  return Astro.redirect("/admin/products");
}

const { data: materials } = await supabaseAdmin
  .from("materials")
  .select("*")
  .eq("active", true)
  .order("sort_order");

const { data: productMaterials } = await supabaseAdmin
  .from("product_materials")
  .select("material_id")
  .eq("product_id", product.id);

const selectedMaterials = new Set(
  productMaterials?.map(pm => pm.material_id) ?? []
);
---

<AdminLayout title="Edit Product" active="products">

<div class="mb-8 flex items-center justify-between">

  <div>
    <h1 class="text-4xl font-bold text-slate-900">
      {product.name}
    </h1>

    <p class="mt-2 text-slate-500">
      Edit Product
      {
  saved && (

    <div class="mb-6 rounded-xl border border-green-300 bg-green-50 px-5 py-4 text-green-800">

      <div class="font-semibold">
        ✅ Product updated successfully.
      </div>

      <div class="text-sm">
        Your changes have been saved.
      </div>

    </div>

  )
}
    </p>
  </div>

  <a
    href="/admin/products"
    class="rounded-lg bg-slate-900 px-5 py-3 text-white hover:bg-slate-700"
  >
    ← Back
  </a>

</div>

<div class="grid gap-8 lg:grid-cols-2">

  <!-- Product Information -->

  <div class="rounded-2xl bg-white p-8 shadow">

    <h2 class="mb-6 text-2xl font-bold">
      Product Information
    </h2>

    <form
      action="/api/admin/update-product"
      method="POST"
      class="space-y-6"
    >

      <input
        type="hidden"
        name="id"
        value={product.id}
      />

      <div>
        <label class="mb-2 block font-semibold">
          Product Name
        </label>

        <input
          name="name"
          value={product.name}
          class="w-full rounded-lg border p-3"
        />
      </div>

      <div>

        <label class="mb-2 block font-semibold">
  PLA Base Price
</label>

<p class="mb-2 text-sm text-slate-500">
  Other material prices are calculated automatically.
</p>

        <input
          type="number"
          step="0.01"
          name="price"
          value={product.price ?? ""}
          class="w-full rounded-lg border p-3"
        />
      </div>

      <div>
        <label class="mb-2 block font-semibold">
          Description
        </label>

        <textarea
          name="description"
          rows="8"
          class="w-full rounded-lg border p-3"
        >{product.description}</textarea>
      </div>

      <div>

  <h3 class="mb-4 text-lg font-semibold">
    Available Materials
  </h3>

  <div class="grid gap-3 md:grid-cols-2">

    {materials?.map((material) => (

      <label class="flex items-center gap-3 rounded-lg border p-3 hover:bg-slate-50">

        <input
          type="checkbox"
          name="materials"
          value={material.id}
          checked={selectedMaterials.has(material.id)}
        />

        <div>

          <div class="font-semibold">
            {material.name}
          </div>

          <div class="text-sm text-slate-500">
            +{material.markup_percent}% from PLA
          </div>

        </div>

      </label>

    ))}

  </div>

</div>

      <button
        class="rounded-lg bg-yellow-400 px-8 py-3 font-semibold hover:bg-yellow-300"
      >
        Save Changes
      </button>

    </form>

  </div>

  <!-- Product Images -->

  <div class="rounded-2xl bg-white p-8 shadow">

    <div class="mb-6 flex items-center justify-between">

      <h2 class="text-2xl font-bold">
        Product Images
      </h2>

    </div>

    <form
      action="/api/admin/upload-product-image"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-4"
    >

      <input
        type="hidden"
        name="product_id"
        value={product.id}
      />

      <input
        type="file"
        name="images"
        multiple
        accept="image/*"
        class="w-full rounded-lg border p-3"
      />

      <button
        class="w-full rounded-lg bg-yellow-400 px-4 py-3 font-semibold hover:bg-yellow-300"
      >
        Upload Images
      </button>

    </form>

    <hr class="my-8" />

    {product.product_images?.length ? (

      <div class="grid grid-cols-2 gap-4 md:grid-cols-3">

  {product.product_images.map((image) => (

    <div class="rounded-xl border bg-white p-3 shadow-sm">

      <div class="flex aspect-square items-center justify-center rounded-lg bg-slate-100 p-2">

        <img
          src={`${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/product-images/${image.image_url}`}
          class="max-h-full max-w-full object-contain"
        />

      </div>

      <form
        action="/api/admin/delete-product-image"
        method="POST"
        class="mt-3"
      >

        <input
          type="hidden"
          name="image_id"
          value={image.id}
        />

        <input
          type="hidden"
          name="product_id"
          value={product.id}
        />

        <button
          class="w-full rounded-lg bg-red-600 py-2 text-sm font-semibold text-white hover:bg-red-700"
        >
          Delete
        </button>

      </form>

    </div>

  ))}

</div>

    ) : (

      <div class="rounded-xl border border-dashed p-12 text-center">

        <p class="text-slate-500">
          No product images uploaded yet.
        </p>

      </div>

    )}

  </div>

</div>

</AdminLayout>