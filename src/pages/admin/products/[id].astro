---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import ProductVariantsField from "../../../components/admin/ProductVariantsField.astro";
import { supabaseAdmin } from "../../../lib/supabaseAdmin";

const { id } = Astro.params;
const saved = Astro.url.searchParams.get("saved") === "1";

if (!id) {
  return Astro.redirect("/admin/products");
}

const { data: product, error: productError } =
  await supabaseAdmin
    .from("products")
    .select(`
      *,
      categories(*),
      product_images(*),
      product_variants(*)
    `)
    .eq("id", id)
    .single();

if (productError || !product) {
  console.error("Unable to load product.", {
    productId: id,
    error: productError,
  });

  return Astro.redirect("/admin/products");
}

const { data: categories, error: categoriesError } =
  await supabaseAdmin
    .from("categories")
    .select("*")
    .order("name");

if (categoriesError) {
  console.error("Unable to load product categories.", {
    productId: product.id,
    error: categoriesError,
  });
}

const { data: materials, error: materialsError } =
  await supabaseAdmin
    .from("materials")
    .select("*")
    .eq("active", true)
    .order("sort_order");

if (materialsError) {
  console.error("Unable to load product materials.", {
    productId: product.id,
    error: materialsError,
  });
}

const {
  data: productMaterials,
  error: productMaterialsError,
} = await supabaseAdmin
  .from("product_materials")
  .select("material_id")
  .eq("product_id", product.id);

if (productMaterialsError) {
  console.error("Unable to load selected materials.", {
    productId: product.id,
    error: productMaterialsError,
  });
}

const selectedMaterials = new Set(
  productMaterials?.map(
    (productMaterial) => productMaterial.material_id,
  ) ?? [],
);

const supabaseUrl =
  import.meta.env.PUBLIC_SUPABASE_URL.replace(/\/+$/, "");

function getProductImageUrl(imagePath: string): string {
  return `${supabaseUrl}/storage/v1/object/public/product-images/${imagePath}`;
}

const productVariants = [...(product.product_variants ?? [])].sort(
  (left, right) => Number(left.sort_order ?? 0) - Number(right.sort_order ?? 0),
);
---

<AdminLayout title="Edit Product" active="products">
  <div class="mb-8 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="text-4xl font-bold text-slate-900">
        {product.name}
      </h1>

      <p class="mt-2 text-slate-500">
        Edit product information, materials, and images.
      </p>
    </div>

    <a
      href="/admin/products"
      class="rounded-lg bg-slate-900 px-5 py-3 text-white hover:bg-slate-700"
    >
      ← Back
    </a>
  </div>

  {
    saved && (
      <div
        class="mb-8 rounded-xl border border-green-300 bg-green-50 px-5 py-4 text-green-800"
        role="status"
      >
        <div class="font-semibold">
          Product updated successfully.
        </div>

        <div class="mt-1 text-sm">
          Your changes have been saved.
        </div>
      </div>
    )
  }

  <div class="grid gap-8 lg:grid-cols-2">
    <section class="rounded-2xl bg-white p-8 shadow">
      <h2 class="mb-6 text-2xl font-bold">
        Product Information
      </h2>

      <form
        action="/api/admin/update-product"
        method="POST"
        enctype="multipart/form-data"
        class="space-y-6"
      >
        <input
          type="hidden"
          name="id"
          value={product.id}
        />

        <div>
          <label
            for="name"
            class="mb-2 block font-semibold"
          >
            Product Name
          </label>

          <input
            id="name"
            name="name"
            value={product.name}
            required
            class="w-full rounded-lg border p-3"
          />
        </div>

        <div>
          <label
            for="brand"
            class="mb-2 block font-semibold"
          >
            Brand (Optional)
          </label>

          <input
            id="brand"
            name="brand"
            maxlength="80"
            value={product.brand ?? ""}
            placeholder="e.g. Bosch, Milwaukee, DEWALT"
            class="w-full rounded-lg border p-3"
          />

          <p class="mt-2 text-sm text-slate-500">
            Customers can use this value to filter products in the Shop.
          </p>
        </div>

        <div>
          <label
            for="category_id"
            class="mb-2 block font-semibold"
          >
            Category
          </label>

          <select
            id="category_id"
            name="category_id"
            required
            class="w-full rounded-lg border p-3"
          >
            {
              categories?.map((category) => (
                <option
                  value={category.id}
                  selected={category.id === product.category_id}
                >
                  {category.name}
                </option>
              ))
            }
          </select>
        </div>

        <div>
          <label
            for="short_description"
            class="mb-2 block font-semibold"
          >
            Short Description
          </label>

          <textarea
            id="short_description"
            name="short_description"
            rows="3"
            class="w-full rounded-lg border p-3"
          >{product.short_description ?? ""}</textarea>
        </div>

        <div>
          <label
            for="description"
            class="mb-2 block font-semibold"
          >
            Description
          </label>

          <textarea
            id="description"
            name="description"
            rows="12"
            class="w-full rounded-lg border p-3"
          >{product.description ?? ""}</textarea>

          <p class="mt-2 text-sm leading-6 text-slate-500">
            Formatting supported: use a blank line for a new paragraph,
            <code class="rounded bg-slate-100 px-1.5 py-0.5">## Heading</code>,
            <code class="rounded bg-slate-100 px-1.5 py-0.5">- Bullet point</code>,
            or <code class="rounded bg-slate-100 px-1.5 py-0.5">1. Numbered step</code>.
            HTML is not required.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class="flex flex-col">
            <label
              for="price"
              class="mb-2 block font-semibold"
            >
              Base Price (PLA)
            </label>

            <p class="mb-2 min-h-10 text-sm text-slate-500">
              Prices for other materials are calculated automatically.
            </p>

            <input
              id="price"
              type="number"
              name="price"
              min="0.01"
              step="0.01"
              value={product.price ?? ""}
              required
              class="w-full rounded-lg border p-3"
            />
          </div>

          <div class="flex flex-col">
            <label
              for="sale_price"
              class="mb-2 block font-semibold"
            >
              Sale Price (Optional)
            </label>

            <p class="mb-2 min-h-10 text-sm text-slate-500">
              Leave blank when the product is not on sale.
            </p>

            <input
              id="sale_price"
              type="number"
              name="sale_price"
              min="0.01"
              step="0.01"
              value={product.sale_price ?? ""}
              class="w-full rounded-lg border p-3"
            />
          </div>
        </div>

        <ProductVariantsField
          variants={productVariants}
          imageBaseUrl={`${supabaseUrl}/storage/v1/object/public/product-images/`}
        />

        <div>
          <label
            for="sku"
            class="mb-2 block font-semibold"
          >
            SKU
          </label>

          <input
            id="sku"
            name="sku"
            value={product.sku ?? ""}
            class="w-full rounded-lg border p-3"
          />
        </div>

        <fieldset>
          <legend class="mb-4 text-lg font-semibold">
            Available Materials
          </legend>

          {
            materials?.length ? (
              <div class="grid gap-3 md:grid-cols-2">
                {materials.map((material) => (
                  <label class="flex items-center gap-3 rounded-lg border p-3 hover:bg-slate-50">
                    <input
                      type="checkbox"
                      name="materials"
                      value={material.id}
                      checked={selectedMaterials.has(
                        material.id,
                      )}
                    />

                    <span>
                      <span class="block font-semibold">
                        {material.name}
                      </span>

                      <span class="block text-sm text-slate-500">
  {
    material.markup_percent === 0
      ? "Base material"
      : `+${material.markup_percent}% from PLA`
  }
</span>
                    </span>
                  </label>
                ))}
              </div>
            ) : (
              <p class="rounded-lg border border-dashed p-4 text-sm text-slate-500">
                No active materials are available.
              </p>
            )
          }
        </fieldset>

        <div class="flex flex-wrap items-center gap-6">
          <label class="flex items-center gap-2">
            <input
              type="checkbox"
              name="featured"
              checked={product.featured === true}
            />

            Featured
          </label>

          <label class="flex items-center gap-2">
            <input
              type="checkbox"
              name="active"
              checked={product.status === "Active"}
            />

            Active
          </label>
        </div>

        <button
          type="submit"
          class="rounded-lg bg-yellow-400 px-8 py-3 font-semibold hover:bg-yellow-300"
        >
          Save Changes
        </button>
      </form>
    </section>

    <section class="rounded-2xl bg-white p-8 shadow">
      <h2 class="mb-6 text-2xl font-bold">
        Product Images
      </h2>

      <form
        action="/api/admin/upload-product-image"
        method="POST"
        enctype="multipart/form-data"
        class="space-y-4"
      >
        <input
          type="hidden"
          name="product_id"
          value={product.id}
        />

        <div>
          <label
            for="images"
            class="mb-2 block font-semibold"
          >
            Upload Images
          </label>

          <input
            id="images"
            type="file"
            name="images"
            multiple
            accept="image/*"
            required
            class="w-full rounded-lg border p-3"
          />

          <p class="mt-2 text-sm text-slate-500">
            Select one or more product images.
          </p>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-yellow-400 px-4 py-3 font-semibold hover:bg-yellow-300"
        >
          Upload Images
        </button>
      </form>

      <hr class="my-8" />

      {
        product.product_images?.length ? (
          <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
            {product.product_images.map((image) => (
              <article class="rounded-xl border bg-white p-3 shadow-sm">
                <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-slate-100 p-2">
                  <img
                    src={getProductImageUrl(image.image_url)}
                    alt={`${product.name} product image`}
                    loading="lazy"
                    class="max-h-full max-w-full object-contain"
                  />
                </div>

                <form
                  action="/api/admin/delete-product-image"
                  method="POST"
                  class="mt-3"
                >
                  <input
                    type="hidden"
                    name="image_id"
                    value={image.id}
                  />

                  <input
                    type="hidden"
                    name="product_id"
                    value={product.id}
                  />

                  <button
                    type="submit"
                    class="w-full rounded-lg bg-red-600 py-2 text-sm font-semibold text-white hover:bg-red-700"
                  >
                    Delete
                  </button>
                </form>
              </article>
            ))}
          </div>
        ) : (
          <div class="rounded-xl border border-dashed p-12 text-center">
            <p class="text-slate-500">
              No product images uploaded yet.
            </p>
          </div>
        )
      }
    </section>
  </div>
</AdminLayout>
