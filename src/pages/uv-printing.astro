---
import MainLayout from "../layouts/MainLayout.astro";

const applications = [
  {
    title: "Drinkware",
    description:
      "Transform tumblers, bottles, and mugs with vibrant, wraparound artwork and personalized designs.",
  },
  {
    title: "Phone Cases",
    description:
      "Create detailed, full-colour cases for gifts, retail collections, teams, and branded merchandise.",
  },
  {
    title: "Signs & Displays",
    description:
      "Print crisp graphics directly onto acrylic, wood, and rigid display materials for a polished finish.",
  },
  {
    title: "Promotional Products",
    description:
      "Make memorable keychains, nameplates, awards, giveaways, and client gifts in small or large runs.",
  },
];

const materials = [
  "Acrylic",
  "Coated metal",
  "Plastic",
  "Wood",
  "Glass",
  "Leatherette",
  "Phone cases",
  "Customer-supplied items",
];
---

<MainLayout title="Custom UV Printing | Layer Forge">
  <section class="relative isolate min-h-[680px] overflow-hidden bg-slate-950 text-white">
    <img
      src="/images/uv-printing/uv-printing-hero.webp"
      alt="UV-printed tumbler, phone case, acrylic sign, and keychain"
      class="absolute inset-0 h-full w-full object-cover object-center lg:object-right"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black via-black/90 to-black/10"></div>

    <div class="relative mx-auto flex min-h-[680px] max-w-7xl items-center px-6 py-24">
      <div class="max-w-2xl">
        <p class="font-semibold uppercase tracking-[0.32em] text-yellow-400">
          Full-colour. Direct-to-product.
        </p>

        <h1 class="mt-5 text-5xl font-black leading-tight sm:text-6xl lg:text-7xl">
          Make everyday products impossible to ignore.
        </h1>

        <p class="mt-7 max-w-xl text-lg leading-8 text-slate-200 sm:text-xl">
          Premium UV printing for custom gifts, branded merchandise,
          promotional products, and one-of-a-kind ideas—produced locally by
          Layer Forge.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/quote/uv-printing"
            class="inline-flex items-center justify-center rounded-xl bg-yellow-400 px-8 py-4 text-lg font-bold text-slate-950 transition hover:bg-yellow-300"
          >
            Request a UV Printing Quote
          </a>

          <a
            href="#possibilities"
            class="inline-flex items-center justify-center rounded-xl border border-white/40 bg-white/10 px-8 py-4 text-lg font-semibold text-white backdrop-blur transition hover:bg-white/20"
          >
            Explore Possibilities
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white">
    <div class="mx-auto grid max-w-7xl gap-px bg-slate-200 sm:grid-cols-2 lg:grid-cols-4">
      <div class="bg-white px-6 py-7 text-center">
        <div class="text-2xl font-black text-slate-950">Full Colour</div>
        <div class="mt-1 text-sm text-slate-500">Vivid CMYK + white ink</div>
      </div>
      <div class="bg-white px-6 py-7 text-center">
        <div class="text-2xl font-black text-slate-950">Fine Detail</div>
        <div class="mt-1 text-sm text-slate-500">Sharp graphics and gradients</div>
      </div>
      <div class="bg-white px-6 py-7 text-center">
        <div class="text-2xl font-black text-slate-950">Durable Finish</div>
        <div class="mt-1 text-sm text-slate-500">Instantly cured UV ink</div>
      </div>
      <div class="bg-white px-6 py-7 text-center">
        <div class="text-2xl font-black text-slate-950">Flexible Runs</div>
        <div class="mt-1 text-sm text-slate-500">One piece to small batches</div>
      </div>
    </div>
  </section>

  <section id="possibilities" class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-semibold uppercase tracking-[0.3em] text-yellow-600">
          What can we print?
        </p>
        <h2 class="mt-4 text-4xl font-black text-slate-950 sm:text-5xl">
          Your artwork, on products people actually use.
        </h2>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          UV ink cures directly onto the surface, producing brilliant colour,
          clean detail, and a professional result across a wide range of items.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2">
        <article class="group overflow-hidden rounded-3xl bg-slate-950 shadow-xl">
          <img
            src="/images/uv-printing/uv-tumbler.webp"
            alt="Colourful mountain artwork UV printed on a stainless steel tumbler"
            loading="lazy"
            class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.03]"
          />
          <div class="p-8 text-white">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-yellow-400">
              Drinkware
            </p>
            <h3 class="mt-3 text-3xl font-bold">Bold colour that wraps around.</h3>
          </div>
        </article>

        <article class="group overflow-hidden rounded-3xl bg-slate-950 shadow-xl">
          <img
            src="/images/uv-printing/uv-phone-cases.webp"
            alt="Three phone cases with detailed full-colour UV-printed artwork"
            loading="lazy"
            class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.03]"
          />
          <div class="p-8 text-white">
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-yellow-400">
              Phone Cases
            </p>
            <h3 class="mt-3 text-3xl font-bold">Fine detail, made personal.</h3>
          </div>
        </article>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          applications.map((application) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
              <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-yellow-400 text-xl font-black text-slate-950">
                +
              </div>
              <h3 class="text-xl font-bold text-slate-950">
                {application.title}
              </h3>
              <p class="mt-3 leading-7 text-slate-600">
                {application.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-semibold uppercase tracking-[0.3em] text-yellow-600">
          Apparel Printing
        </p>
        <h2 class="mt-4 text-4xl font-black text-slate-950 sm:text-5xl">
          Custom apparel, two powerful print methods.
        </h2>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Add bold branding, artwork, and personalized designs to shirts,
          hoodies, tote bags, and more with DTF and DTG printing.
        </p>
      </div>

      <div class="mt-16 grid gap-10 lg:grid-cols-2">
        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-lg">
          <img
            src="/images/uv-printing/dtf-apparel.webp"
            alt="Hoodie and tote bag featuring vibrant DTF-printed artwork"
            loading="lazy"
            class="aspect-square w-full object-cover"
          />
          <div class="p-8 sm:p-10">
            <div class="flex items-center gap-4">
              <span class="rounded-full bg-yellow-400 px-4 py-2 text-sm font-black tracking-wider text-slate-950">
                DTF
              </span>
              <span class="text-sm font-semibold uppercase tracking-wider text-slate-500">
                Direct to Film
              </span>
            </div>

            <h3 class="mt-6 text-3xl font-black text-slate-950">
              Bright, versatile, and built to stand out.
            </h3>
            <p class="mt-4 leading-7 text-slate-600">
              DTF transfers deliver vivid colour and strong detail across
              cotton, polyester, blends, and many dark or light garments. It’s
              a flexible choice for logos, team wear, workwear, and custom
              merchandise.
            </p>

            <ul class="mt-6 grid gap-3 text-sm font-semibold text-slate-700 sm:grid-cols-2">
              <li>✓ Cotton and blends</li>
              <li>✓ Light and dark fabrics</li>
              <li>✓ Fine details and colour</li>
              <li>✓ Small or batch orders</li>
            </ul>
          </div>
        </article>

        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-lg">
          <img
            src="/images/uv-printing/dtg-apparel.webp"
            alt="Cotton T-shirts featuring soft, detailed DTG-printed artwork"
            loading="lazy"
            class="aspect-square w-full object-cover"
          />
          <div class="p-8 sm:p-10">
            <div class="flex items-center gap-4">
              <span class="rounded-full bg-slate-950 px-4 py-2 text-sm font-black tracking-wider text-white">
                DTG
              </span>
              <span class="text-sm font-semibold uppercase tracking-wider text-slate-500">
                Direct to Garment
              </span>
            </div>

            <h3 class="mt-6 text-3xl font-black text-slate-950">
              Soft-hand prints with exceptional detail.
            </h3>
            <p class="mt-4 leading-7 text-slate-600">
              DTG prints ink directly into cotton fibres for a smooth,
              breathable finish. It excels at artwork with gradients,
              photographs, subtle colour changes, and intricate illustrations.
            </p>

            <ul class="mt-6 grid gap-3 text-sm font-semibold text-slate-700 sm:grid-cols-2">
              <li>✓ Best for cotton apparel</li>
              <li>✓ Soft, natural feel</li>
              <li>✓ Detailed artwork</li>
              <li>✓ Full-colour gradients</li>
            </ul>
          </div>
        </article>
      </div>

      <div class="mt-12 rounded-3xl bg-yellow-400 p-8 sm:flex sm:items-center sm:justify-between sm:gap-8 sm:p-10">
        <div>
          <h3 class="text-2xl font-black text-slate-950">
            Not sure whether DTF or DTG fits your project?
          </h3>
          <p class="mt-2 text-slate-700">
            Tell us about the garment, artwork, quantity, and finish you want.
          </p>
        </div>
        <a
          href="/contact"
          class="mt-6 inline-flex shrink-0 rounded-xl bg-slate-950 px-7 py-4 font-bold text-white transition hover:bg-slate-800 sm:mt-0"
        >
          Discuss Your Apparel Project
        </a>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-24 text-white">
    <div class="mx-auto grid max-w-7xl gap-16 px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="font-semibold uppercase tracking-[0.3em] text-yellow-400">
          Materials
        </p>
        <h2 class="mt-4 text-4xl font-black sm:text-5xl">
          Print beyond paper.
        </h2>
        <p class="mt-6 text-lg leading-8 text-slate-300">
          UV printing works on flat and gently curved products made from many
          common materials. Send us your item or idea and we’ll confirm fit,
          print area, and artwork requirements before production.
        </p>

        <a
          href="/quote/uv-printing"
          class="mt-9 inline-flex rounded-xl bg-yellow-400 px-7 py-4 font-bold text-slate-950 transition hover:bg-yellow-300"
        >
          Check Your Product
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {
          materials.map((material) => (
            <div class="flex min-h-28 items-center justify-center rounded-2xl border border-white/10 bg-white/5 p-5 text-center font-semibold text-slate-100">
              {material}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center">
        <p class="font-semibold uppercase tracking-[0.3em] text-yellow-600">
          Simple process
        </p>
        <h2 class="mt-4 text-4xl font-black text-slate-950 sm:text-5xl">
          From idea to finished product.
        </h2>
      </div>

      <div class="mt-14 grid gap-8 md:grid-cols-3">
        <article class="rounded-3xl bg-slate-50 p-8">
          <div class="text-5xl font-black text-yellow-400">01</div>
          <h3 class="mt-6 text-2xl font-bold text-slate-950">Share your idea</h3>
          <p class="mt-3 leading-7 text-slate-600">
            Upload your artwork, choose a product, and tell us the quantity and deadline.
          </p>
        </article>
        <article class="rounded-3xl bg-slate-50 p-8">
          <div class="text-5xl font-black text-yellow-400">02</div>
          <h3 class="mt-6 text-2xl font-bold text-slate-950">Approve the plan</h3>
          <p class="mt-3 leading-7 text-slate-600">
            We review the item and print area, then provide pricing and production details.
          </p>
        </article>
        <article class="rounded-3xl bg-slate-50 p-8">
          <div class="text-5xl font-black text-yellow-400">03</div>
          <h3 class="mt-6 text-2xl font-bold text-slate-950">We print it</h3>
          <p class="mt-3 leading-7 text-slate-600">
            Your design is printed, UV-cured, quality checked, and prepared for pickup or shipping.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-yellow-400 py-20">
    <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-6 lg:flex-row lg:items-center">
      <div>
        <p class="font-semibold uppercase tracking-[0.3em] text-slate-700">
          Have something in mind?
        </p>
        <h2 class="mt-3 max-w-3xl text-4xl font-black text-slate-950 sm:text-5xl">
          Let’s put your design on something remarkable.
        </h2>
      </div>
      <a
        href="/quote/uv-printing"
        class="shrink-0 rounded-xl bg-slate-950 px-8 py-4 text-lg font-bold text-white transition hover:bg-slate-800"
      >
        Start Your Quote
      </a>
    </div>
  </section>
</MainLayout>
