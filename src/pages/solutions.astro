---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Solutions | Layer Forge">

<section class="bg-slate-950 text-white">

  <div class="mx-auto max-w-7xl px-6 py-24 text-center">

    <p class="font-semibold uppercase tracking-[0.3em] text-yellow-400">
      SOLUTIONS
    </p>

    <h1 class="mt-4 text-5xl font-bold md:text-6xl">
      Professional Manufacturing Services
    </h1>

    <p class="mx-auto mt-6 max-w-3xl text-xl text-slate-300">
      From concept to completion, we provide high-quality 3D printing,
      laser engraving, and UV printing services tailored to your unique needs.
    </p>

  </div>

</section>

<section class="bg-white py-24">

  <div class="mx-auto grid max-w-7xl items-center gap-16 px-6 lg:grid-cols-2">

    <!-- Image -->
    <div>
      <img
        src="/images/solutions/3d-printing-service.png"
        alt="3D Printing Service"
        class="rounded-3xl shadow-2xl"
      />
    </div>

    <!-- Content -->
    <div>

      <p class="font-semibold uppercase tracking-[0.3em] text-yellow-500">
        3D PRINTING
      </p>

      <h2 class="mt-4 text-5xl font-bold text-slate-900">
        Turn Your Ideas into Reality
      </h2>

      <p class="mt-8 text-lg leading-8 text-slate-600">
        Whether you need a functional replacement part, a prototype, or a
        completely custom design, our professional 3D printing service delivers
        durable, high-quality results tailored to your needs.
      </p>

      <h3 class="mt-10 text-xl font-semibold text-slate-900">
        Common Applications
      </h3>

      <ul class="mt-4 space-y-3 text-slate-600">

        <li>✓ Functional Parts</li>

        <li>✓ Replacement Components</li>

        <li>✓ Prototypes</li>

        <li>✓ Workshop Organization</li>

        <li>✓ Automotive Accessories</li>

        <li>✓ Custom Designs</li>

      </ul>

      <a
        href="/contact"
        class="mt-10 inline-flex rounded-lg bg-yellow-400 px-6 py-3 font-semibold text-black transition hover:bg-yellow-300"
      >
        Request a Quote
      </a>

    </div>

  </div>

</section>

<section class="bg-slate-100 py-24">

  <div class="mx-auto grid max-w-7xl items-center gap-16 px-6 lg:grid-cols-2">

    <!-- Content -->
    <div>

      <p class="font-semibold uppercase tracking-[0.3em] text-yellow-500">
        LASER ENGRAVING
      </p>

      <h2 class="mt-4 text-5xl font-bold text-slate-900">
        Precision Engraving That Lasts
      </h2>

      <p class="mt-8 text-lg leading-8 text-slate-600">
        Add a personal or professional touch with high-precision laser engraving.
        From personalized gifts and business signage to awards and custom branding,
        we create crisp, permanent engravings on a wide range of materials.
      </p>

      <h3 class="mt-10 text-xl font-semibold text-slate-900">
        Common Applications
      </h3>

      <ul class="mt-4 space-y-3 text-slate-600">
        <li>✓ Personalized Gifts</li>
        <li>✓ Wooden Signs & Plaques</li>
        <li>✓ Slate Coasters</li>
        <li>✓ Acrylic Products</li>
        <li>✓ Business Branding</li>
        <li>✓ Awards & Recognition</li>
      </ul>

      <a
        href="/contact"
        class="mt-10 inline-flex rounded-lg bg-yellow-400 px-6 py-3 font-semibold text-black transition hover:bg-yellow-300"
      >
        Request a Quote
      </a>

    </div>

    <!-- Image -->
    <div>
      <img
        src="/images/solutions/laser-engraving-service.png"
        alt="Laser Engraving Service"
        class="rounded-3xl shadow-2xl"
      />
    </div>

  </div>

</section>

<section class="bg-white py-24">

  <div class="mx-auto grid max-w-7xl items-center gap-16 px-6 lg:grid-cols-2">

    <!-- Image -->
    <div>
      <img
        src="/images/solutions/uv-printing-service.png"
        alt="UV Printing Service"
        class="rounded-3xl shadow-2xl"
      />
    </div>

    <!-- Content -->
    <div>

      <p class="font-semibold uppercase tracking-[0.3em] text-yellow-500">
        UV PRINTING
      </p>

      <h2 class="mt-4 text-5xl font-bold text-slate-900">
        Vibrant, Full-Color Printing That Stands Out
      </h2>

      <p class="mt-8 text-lg leading-8 text-slate-600">
        Create eye-catching promotional products, personalized gifts, and custom
        branded merchandise with vibrant UV printing. We produce durable,
        full-color prints directly onto a wide variety of materials with
        exceptional detail and long-lasting quality.
      </p>

      <h3 class="mt-10 text-xl font-semibold text-slate-900">
        Common Applications
      </h3>

      <ul class="mt-4 space-y-3 text-slate-600">
        <li>✓ Promotional Products</li>
        <li>✓ Drinkware & Tumblers</li>
        <li>✓ Employee & Client Gifts</li>
        <li>✓ Business Branding</li>
        <li>✓ Acrylic Signs & Displays</li>
        <li>✓ Personalized Products</li>
      </ul>

      <a
        href="/contact"
        class="mt-10 inline-flex rounded-lg bg-yellow-400 px-6 py-3 font-semibold text-black transition hover:bg-yellow-300"
      >
        Request a Quote
      </a>

    </div>

  </div>

</section>


</MainLayout>