---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Order Successful | Layer Forge">

  <section class="mx-auto max-w-3xl px-6 py-20">

    <div class="rounded-2xl bg-white p-10 text-center shadow-lg">

      <div class="mb-6 text-6xl">
        ✅
      </div>

      <h1 class="mb-4 text-4xl font-bold">
        Thank You for Your Order!
      </h1>

      <p class="mb-2 text-lg text-slate-600">
        Your payment has been received successfully.
      </p>

      <div class="mt-6 rounded-xl border-2 border-yellow-400 bg-yellow-50 p-5 text-left text-sm leading-6 text-slate-800">
        <strong class="block text-slate-950">
          Final sale — paid orders are non-refundable
        </strong>
        Once payment is completed, the order is final and non-refundable,
        except where required by applicable law.
      </div>

      <div class="rounded-xl bg-slate-50 p-6 text-left">

        <h2 class="mb-4 text-xl font-semibold">
          What happens next?
        </h2>

        <ul class="space-y-3 text-slate-600">
          <li>• Your order has been received.</li>
          <li>• Your order is confirmed and awaiting production.</li>
          <li>• You'll receive an email confirmation.</li>
          <li>• We'll notify you when your order is ready or shipped.</li>
        </ul>

      </div>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">

        <a
          href="/shop"
          class="rounded-xl bg-yellow-400 px-8 py-4 font-semibold text-slate-950 hover:bg-yellow-300"
        >
          Continue Shopping
        </a>

        <a
          href="/"
          class="rounded-xl border px-8 py-4 font-semibold hover:bg-slate-100"
        >
          Return Home
        </a>

      </div>

    </div>

  </section>

  <script type="module">
    import { clearCart } from "../../features/cart/cartStorage";

    clearCart();
  </script>

</MainLayout>
