---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Request a Quote | Layer Forge">

<section class="bg-slate-50 py-20">

  <div class="mx-auto max-w-7xl px-6">

    <!-- Hero -->

    <div class="mx-auto max-w-4xl text-center">

      <h1 class="text-5xl font-bold text-slate-900">
        Request a Quote
      </h1>

      <p class="mt-6 text-xl leading-8 text-slate-600">
        Choose the service you're interested in. We'll review your project
        requirements and provide a personalized quote with pricing,
        turnaround time and available options.
      </p>

    </div>

    <!-- Services -->

    <div class="mt-20 grid gap-10 lg:grid-cols-3">

      <!-- 3D Printing -->

      <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg transition duration-300 hover:-translate-y-1 hover:shadow-xl">

        <div class="aspect-video overflow-hidden bg-slate-950">
          <img
            src="/images/3d-printing/3d-printing-hero.webp"
            alt="A selection of functional 3D-printed parts"
            width="1672"
            height="941"
            class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.03]"
            decoding="async"
          />
        </div>

        <div class="flex flex-1 flex-col p-8">

          <h2 class="text-3xl font-bold text-slate-900">
            3D Printing
          </h2>

          <p class="mt-4 text-slate-600">
            Functional parts, prototypes, replacement components and custom
            manufacturing.
          </p>

          <ul class="mb-8 mt-6 space-y-2 text-slate-700">

            <li>✓ PLA / PETG / ABS</li>
            <li>✓ Custom Colours</li>
            <li>✓ Production Runs</li>

          </ul>

          <a
            href="/quote/3d-printing"
            class="mt-auto flex h-12 items-center justify-center rounded-xl bg-yellow-400 font-semibold text-slate-900 transition hover:bg-yellow-300"
          >
            Start Quote
          </a>

        </div>

      </article>

      <!-- Laser Engraving -->

      <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg transition duration-300 hover:-translate-y-1 hover:shadow-xl">

        <div class="aspect-video overflow-hidden bg-slate-950">
          <img
            src="/images/laser-engraving/laser-engraving-hero.webp"
            alt="A collection of laser-engraved products"
            width="1672"
            height="941"
            class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.03]"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="flex flex-1 flex-col p-8">

          <h2 class="text-3xl font-bold text-slate-900">
            Laser Engraving
          </h2>

          <p class="mt-4 text-slate-600">
            Personalized gifts, drinkware, awards, plaques and business
            branding.
          </p>

          <ul class="mb-8 mt-6 space-y-2 text-slate-700">

            <li>✓ Stainless Steel</li>
            <li>✓ Wood</li>
            <li>✓ Glass & Acrylic</li>

          </ul>

          <a
            href="/quote/laser-engraving"
            class="mt-auto flex h-12 items-center justify-center rounded-xl bg-yellow-400 font-semibold text-slate-900 transition hover:bg-yellow-300"
          >
            Start Quote
          </a>

        </div>

      </article>

      <!-- UV Printing -->

      <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg transition duration-300 hover:-translate-y-1 hover:shadow-xl">

        <div class="aspect-video overflow-hidden bg-slate-950">
          <img
            src="/images/uv-printing/uv-printing-hero.webp"
            alt="Full-colour UV-printed products"
            width="1672"
            height="941"
            class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.03]"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="flex flex-1 flex-col p-8">

          <h2 class="text-3xl font-bold text-slate-900">
            UV Printing
          </h2>

          <p class="mt-4 text-slate-600">
            High-resolution full-colour printing on rigid and customer-supplied
            materials.
          </p>

          <ul class="mb-8 mt-6 space-y-2 text-slate-700">

            <li>✓ Acrylic</li>
            <li>✓ Metal</li>
            <li>✓ Plastic & Wood</li>

          </ul>

          <a
            href="/quote/uv-printing"
            class="mt-auto flex h-12 items-center justify-center rounded-xl bg-yellow-400 font-semibold text-slate-900 transition hover:bg-yellow-300"
          >
            Start Quote
          </a>

        </div>

      </article>

    </div>

    <!-- Bottom CTA -->

    <div class="mt-20 rounded-3xl bg-slate-900 px-10 py-14 text-center text-white">

      <h2 class="text-4xl font-bold">
        Not Sure Which Service You Need?
      </h2>

      <p class="mx-auto mt-5 max-w-3xl text-lg text-slate-300">
        Contact us with your project details and we'll recommend the best
        manufacturing process for your application.
      </p>

      <a
        href="/contact"
        class="mt-8 inline-flex rounded-xl bg-yellow-400 px-10 py-4 text-lg font-semibold text-slate-900 transition hover:bg-yellow-300"
      >
        Contact Us
      </a>

    </div>

  </div>

</section>

</MainLayout>
