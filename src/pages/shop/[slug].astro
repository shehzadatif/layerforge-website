---
import MainLayout from "../../layouts/MainLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import ProductConfigurator from "../../features/shop/components/ProductConfigurator/ProductConfigurator";

export const prerender = false;

const { slug } = Astro.params;

const { data: product } = await supabaseAdmin
  .from("products")
  .select(`
    *,
    categories(name),
    product_images(*),
    product_materials(
      material_id,
      override_markup_percent,
      materials(
        id,
        name,
        markup_percent,
        default_production_days
      )
    )
  `)
  .eq("slug", slug)
  .single();

if (!product) {
  return Astro.redirect("/shop");
}

const images = (product.product_images ?? []).sort(
  (a, b) => a.sort_order - b.sort_order
);

const cover = images[0];
---

<MainLayout title={product.name}>

<section class="bg-slate-50 py-20">

  <div class="mx-auto max-w-7xl px-6">

    <div class="grid gap-12 lg:grid-cols-2">

      <!-- Images -->

      <div>

        <div class="overflow-hidden rounded-2xl bg-white shadow">

          {
            cover ? (

              <img
                src={`${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/product-images/${cover.image_url}`}
                alt={product.name}
                class="w-full object-contain"
              />

            ) : (

              <div class="flex h-96 items-center justify-center">

                No Image

              </div>

            )
          }

        </div>

        {
          images.length > 1 && (

            <div class="mt-6 grid grid-cols-4 gap-3">

              {images.map((image) => (

                <img
                  src={`${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/product-images/${image.image_url}`}
                  alt={product.name}
                  class="aspect-square rounded-lg border object-cover cursor-pointer"
                />

              ))}

            </div>

          )
        }

      </div>

      <!-- Product Information -->

      <div>

        <p class="mb-2 text-sm uppercase text-slate-500">
          {product.categories?.name}
        </p>

        <h1 class="mb-6 text-5xl font-bold">
          {product.name}
        </h1>

        <p class="mb-8 text-lg text-slate-600">
          {product.description}
        </p>

        <ProductConfigurator
          client:load
          product={product}
        />

      </div>

    </div>

  </div>

</section>

</MainLayout>