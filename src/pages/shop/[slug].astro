---
import MainLayout from "../../layouts/MainLayout.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import ProductGallery from "../../features/shop/components/ProductGallery/ProductGallery";
import ProductConfiguratorWithProvider from "../../features/shop/components/ProductConfigurator/ProductConfiguratorWithProvider";

export const prerender = false;

const { slug } = Astro.params;

const { data: product } = await supabaseAdmin
  .from("products")
  .select(`
    *,
    categories(name),
    product_images(*),
    product_materials(
      material_id,
      materials(
        id,
        name,
        markup_percent,
        default_production_days
      )
    )
  `)
  .eq("slug", slug)
  .single();

if (!product) {
  return Astro.redirect("/shop");
}

const imageUrls = (product.product_images ?? [])
  .sort((a, b) => a.sort_order - b.sort_order)
  .map(
    (image) =>
      `${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/product-images/${image.image_url}`
  );

const cover = imageUrls[0] ?? "";
---

<MainLayout title={product.name}>

<section class="bg-slate-50 py-20">

  <div class="mx-auto max-w-7xl px-6">

    <div class="grid gap-12 lg:grid-cols-2">

      <!-- Product Gallery -->

      <ProductGallery
        client:load
        images={imageUrls}
        productName={product.name}
      />

      <!-- Product Information -->

      <div>

        <p class="mb-2 text-sm uppercase text-slate-500">
          {product.categories?.name}
        </p>

        <h1 class="mb-6 text-5xl font-bold">
          {product.name}
        </h1>

        <p class="mb-8 text-lg text-slate-600">
          {product.description}
        </p>

        <ProductConfiguratorWithProvider
          client:load
          product={product}
          image={cover}
        />

      </div>

    </div>

  </div>

</section>

</MainLayout>