---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductDescription from "../../components/products/ProductDescription.astro";
import { supabaseAdmin } from "../../lib/supabaseAdmin";
import ProductGallery from "../../features/shop/components/ProductGallery/ProductGallery";
import ProductConfiguratorWithProvider from "../../features/shop/components/ProductConfigurator/ProductConfiguratorWithProvider";

export const prerender = false;

const { slug } = Astro.params;

const { data: product } = await supabaseAdmin
  .from("products")
  .select(`
    *,
    categories(name),
    product_images(*),
    product_variants(*),
    product_materials(
      material_id,
      materials(
        id,
        name,
        markup_percent,
        default_production_days
      )
    )
  `)
  .eq("slug", slug)
  .single();

if (!product) {
  return Astro.redirect("/shop");
}

const publicImageBase =
  `${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/product-images/`;

function getPublicImageUrl(imagePath: string): string {
  return imagePath.startsWith("http://") || imagePath.startsWith("https://")
    ? imagePath
    : `${publicImageBase}${imagePath}`;
}

const productImageUrls = (product.product_images ?? [])
  .sort((a, b) => a.sort_order - b.sort_order)
  .map((image) => getPublicImageUrl(image.image_url));

const storefrontVariants = [...(product.product_variants ?? [])]
  .sort(
    (left, right) =>
      Number(left.sort_order ?? 0) - Number(right.sort_order ?? 0),
  )
  .map((variant) => ({
    ...variant,
    image_url: variant.image_url
      ? getPublicImageUrl(variant.image_url)
      : null,
  }));

const variantImageUrls = storefrontVariants
  .map((variant) => variant.image_url)
  .filter((imageUrl): imageUrl is string => Boolean(imageUrl));

const galleryImageUrls = [
  ...new Set([...productImageUrls, ...variantImageUrls]),
];

const cover = productImageUrls[0] ?? variantImageUrls[0] ?? "";

const storefrontProduct = {
  ...product,
  product_variants: storefrontVariants,
};
---

<MainLayout title={product.name}>

<section class="bg-slate-50 py-20">

  <div class="mx-auto max-w-7xl px-6">

    <div class="grid gap-12 lg:grid-cols-2">

      <!-- Product Gallery -->

      <ProductGallery
        client:load
        images={galleryImageUrls}
        productName={product.name}
      />

      <!-- Product Information -->

      <div>

        <p class="mb-2 text-sm uppercase text-slate-500">
          {product.categories?.name}
        </p>

        <h1 class="mb-6 text-5xl font-bold">
          {product.name}
        </h1>

        <ProductDescription
          description={product.description}
          productName={product.name}
        />

        <ProductConfiguratorWithProvider
          client:load
          product={storefrontProduct}
          image={cover}
        />

      </div>

    </div>

  </div>

</section>

</MainLayout>
