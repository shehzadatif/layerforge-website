---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Laser Engraving Services | Layer Forge">

<!-- Hero -->
<section class="bg-gray-950 text-white">

  <div class="mx-auto max-w-7xl px-6 py-20">

    <div class="grid items-center gap-12 lg:grid-cols-2">

      <div>

        <p class="uppercase tracking-[0.3em] text-yellow-400 font-semibold">
          LASER ENGRAVING SERVICES
        </p>

        <h1 class="mt-4 text-5xl font-bold leading-tight">
          Precision Engraving That Lasts
        </h1>

        <p class="mt-6 text-xl text-gray-300 leading-8">
          Personalize gifts, awards, drinkware, business products,
          signage and keepsakes with crisp, permanent laser engraving
          on a wide variety of materials.
        </p>

        <div class="mt-10 flex gap-4">

          <a
            href="/contact"
            class="rounded-lg bg-yellow-400 px-8 py-4 font-semibold text-black hover:bg-yellow-300"
          >
            Get a Quote
          </a>

          <a
            href="/portfolio"
            class="rounded-lg border border-white px-8 py-4 hover:bg-white hover:text-black"
          >
            View Portfolio
          </a>

        </div>

      </div>

      <div>

        <img
          src="/images/products/laser-engraving.png"
          alt="Laser Engraving"
          class="rounded-3xl shadow-2xl"
        />

      </div>

    </div>

  </div>

</section>

<!-- What We Can Engrave -->

<section class="bg-white py-20">

  <div class="mx-auto max-w-7xl px-6">

    <h2 class="text-center text-4xl font-bold">
      What We Can Engrave
    </h2>

    <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      <div class="rounded-xl border p-8">
        <h3 class="text-2xl font-semibold">Personalized Gifts</h3>
        <p class="mt-4 text-gray-600">
          Coasters, tumblers, keychains, cutting boards,
          plaques and keepsakes.
        </p>
      </div>

      <div class="rounded-xl border p-8">
        <h3 class="text-2xl font-semibold">Business Branding</h3>
        <p class="mt-4 text-gray-600">
          Business logos, promotional products,
          awards and corporate gifts.
        </p>
      </div>

      <div class="rounded-xl border p-8">
        <h3 class="text-2xl font-semibold">Custom Projects</h3>
        <p class="mt-4 text-gray-600">
          Unique engraved products created
          specifically for your requirements.
        </p>
      </div>

    </div>

  </div>

</section>

</MainLayout>