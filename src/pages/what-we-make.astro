---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="What We Make | Layer Forge">

<section class="bg-gray-950 text-white">

  <div class="mx-auto max-w-7xl px-6 py-24 text-center">

    <p class="font-semibold uppercase tracking-[0.3em] text-yellow-400">
      WHAT WE MAKE
    </p>

    <h1 class="mt-4 text-5xl font-bold md:text-6xl">
      Custom Solutions for Every Idea
    </h1>

    <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-300">
      Whether you need a one-of-a-kind gift, a functional workshop accessory,
      business branding, custom apparel, or a production-ready part,
      Layer Forge helps bring your ideas to life.
    </p>

  </div>

</section>

</MainLayout>