---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/products/ProductCard.astro';
---

<MainLayout title="Products | Layer Forge">

  <!-- Hero Section -->
  <section class="bg-gray-950 text-white">

    <div class="mx-auto max-w-7xl px-6 py-24">

      <p class="font-semibold uppercase tracking-[0.3em] text-yellow-400">
        WHAT WE CREATE
      </p>

      <h1 class="mt-4 text-5xl font-bold md:text-6xl">
        Custom Manufacturing Solutions
      </h1>

      <p class="mt-6 max-w-3xl text-xl text-gray-300">
        Layer Forge combines modern manufacturing technologies
        to create functional products, personalized gifts,
        business branding, prototypes and completely custom solutions.
      </p>

    </div>

  </section>

  <!-- 👇 ADD THE PRODUCT CARD SECTION HERE -->
  <section class="bg-gray-100 py-20">

    <div class="space-y-16">

  <ProductCard
    title="3D Printing Solutions"
    image="/images/products/3d-printing.png"
    description="From functional prototypes and replacement parts to workshop organizers and custom accessories, we transform your ideas into durable, high-quality 3D printed products."
    link="/products/3d-printing"
  />

  <ProductCard
    title="Laser Engraving Services"
    image="/images/products/laser-engraving.png"
    description="Create personalized gifts, engraved tumblers, plaques, awards, business branding, and custom keepsakes with precision laser engraving."
    link="/products/laser-engraving"
  />

  <ProductCard
    title="UV Printing Solutions"
    image="/images/products/uv-printing.png"
    description="Bring your designs to life with vibrant full-color UV printing on acrylic, wood, leather, promotional products, signage, and more."
    link="/products/uv-printing"
  />

</div>

  </section>

</MainLayout>