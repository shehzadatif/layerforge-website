---
import MainLayout from "../layouts/MainLayout.astro";
import { supabaseAdmin } from "../lib/supabaseAdmin";

const { data: products } = await supabaseAdmin
  .from("products")
  .select(`
    *,
    categories(name),
    product_images(*)
  `)
  .eq("status", "Active")
  .order("created_at", { ascending: false });
---

<MainLayout title="Project Gallery | Layer Forge">

<section class="py-20">

  <div class="mx-auto max-w-7xl px-6">

    <div class="mb-12 text-center">

      <h1 class="text-5xl font-bold">
        Project Gallery
      </h1>

      <p class="mt-4 text-lg text-slate-600">
        Browse examples of our custom fabrication work.
      </p>

    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

      {products?.map((product) => {

        const cover = product.product_images
          ?.sort((a, b) => a.sort_order - b.sort_order)[0];

        return (

          <a
            href={`/gallery/${product.slug}`}
            class="overflow-hidden rounded-2xl bg-white shadow transition hover:-translate-y-1 hover:shadow-xl"
          >

            <div class="aspect-square bg-slate-100">

              {cover ? (

                <img
                  src={`${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/product-images/${cover.image_url}`}
                  class="h-full w-full object-cover"
                  alt={product.name}
                />

              ) : (

                <div class="flex h-full items-center justify-center text-slate-400">
                  No Image
                </div>

              )}

            </div>

            <div class="p-6">

              <h2 class="text-xl font-bold">
                {product.name}
              </h2>

              <p class="mt-2 text-slate-500 line-clamp-3">
                {product.short_description}
              </p>

            </div>

          </a>

        );

      })}

    </div>

  </div>

</section>

</MainLayout>