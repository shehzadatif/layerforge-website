---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Our Services | Layer Forge">

<section class="bg-slate-50">

  <!-- Hero -->
  <div class="mx-auto max-w-7xl px-6 py-20">

    <div class="mx-auto max-w-4xl text-center">

      <h1 class="text-5xl font-bold text-slate-900">
        Our Services
      </h1>

      <p class="mt-6 text-xl leading-8 text-slate-600">
        Layer Forge provides professional 3D Printing, Laser Engraving and UV Printing with precision manufacturing 
        and personalization services for hobbyists, makers, businesses and industrial customers. 
        Whether you need one custom part or a production run, we're here to
        help bring your ideas to life.
      </p>

    </div>

  </div>

  <!-- ================================================= -->
  <!-- 3D PRINTING -->
  <!-- ================================================= -->

  <section class="bg-white">

    <div class="mx-auto grid max-w-7xl items-center gap-14 px-6 py-20 lg:grid-cols-2">

      <div>

        <img
          src="/images/3d-printing/3d-printing-hero.webp"
          alt="A selection of functional 3D-printed parts"
          width="1672"
          height="941"
          class="mx-auto aspect-video w-full max-w-xl rounded-2xl object-cover shadow-lg"
          decoding="async"
        />

      </div>

      <div>

        <span class="rounded-full bg-yellow-400 px-4 py-2 text-sm font-semibold tracking-wide text-slate-900">
          3D PRINTING
        </span>

        <h2 class="mt-6 text-3xl font-bold text-slate-900">
          Precision Manufacturing
        </h2>

        <p class="mt-5 text-base leading-7 text-slate-600">
          We manufacture high-quality functional parts, rapid prototypes and
          custom products using professional FDM 3D printing technology. From
          single prototypes to small production runs, we deliver accurate,
          durable components tailored to your needs.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Functional Parts
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Rapid Prototypes
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Replacement Parts
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Custom Designs
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Engineering Plastics
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Small Batch Production
          </div>

        </div>

        <a
          href="/quote/3d-printing"
          class="mt-10 inline-flex items-center justify-center rounded-xl bg-yellow-400 px-8 py-2 text-lg font-semibold text-slate-900 transition hover:bg-yellow-300"
        >
          Request Quote
        </a>

      </div>

    </div>

  </section>

  <!-- ================================================= -->
  <!-- LASER ENGRAVING -->
  <!-- ================================================= -->

  <section class="bg-slate-50">

    <div class="mx-auto grid max-w-7xl items-center gap-14 px-6 py-20 lg:grid-cols-2">

      <div class="order-2 lg:order-1">

        <span class="rounded-full bg-yellow-400 px-4 py-2 text-sm font-semibold tracking-wide text-slate-900">
          LASER ENGRAVING
        </span>

        <h2 class="mt-6 text-3xl font-bold text-slate-900">
          Permanent Personalization
        </h2>

        <p class="mt-5 text-base leading-7 text-slate-600">
          Create memorable gifts, branded merchandise and personalized products
          with crisp, permanent laser engraving. We engrave a wide variety of
          materials with exceptional precision.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Tumblers
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Flasks
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Cutting Boards
          </div>

         <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Plaques
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Awards
          </div>

         <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Corporate Gifts
          </div>

        </div>

        <a
          href="/quote/laser-engraving"
          class="mt-10 inline-flex items-center justify-center rounded-xl bg-yellow-400 px-8 py-2 text-lg font-semibold text-slate-900 transition hover:bg-yellow-300"
        >
          Request Quote
        </a>

      </div>

      <div class="order-1 lg:order-2">

        <img
          src="/images/laser-engraving/laser-engraving-hero.webp"
          alt="A collection of laser-engraved products"
          width="1672"
          height="941"
          class="mx-auto aspect-video w-full max-w-xl rounded-2xl object-cover shadow-lg"
          loading="lazy"
          decoding="async"
        />

      </div>

    </div>

  </section>

    <!-- ================================================= -->
  <!-- UV PRINTING -->
  <!-- ================================================= -->

  <section class="bg-white">

     <div class="mx-auto grid max-w-7xl items-center gap-14 px-6 py-20 lg:grid-cols-2">

      <div>

        <img
          src="/images/uv-printing/uv-printing-hero.webp"
          alt="Full-colour UV-printed products"
          width="1672"
          height="941"
          class="mx-auto aspect-video w-full max-w-xl rounded-2xl object-cover shadow-lg"
          loading="lazy"
          decoding="async"
        />

      </div>

      <div>

        <span class="rounded-full bg-yellow-400 px-4 py-2 text-sm font-semibold tracking-wide text-slate-900">
          UV PRINTING
        </span>

        <h2 class="mt-6 text-3xl font-bold text-slate-900">
          Brilliant Full-Colour Printing
        </h2>

        <p class="mt-5 text-base leading-7 text-slate-600">
          Produce vibrant, durable, full-colour prints directly onto acrylic,
          wood, plastic, metal, glass and many customer-supplied products using
          state-of-the-art UV printing technology.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Acrylic Signs
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Promotional Products
          </div>

         <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Phone Cases
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Business Branding
          </div>

         <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Customer-Supplied Items
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
            ✓ Custom Projects
          </div>

        </div>

        <a
          href="/quote/uv-printing"
           class="mt-10 inline-flex items-center justify-center rounded-xl bg-yellow-400 px-8 py-2 text-lg font-semibold text-slate-900 transition hover:bg-yellow-300"
        >
          Request Quote
        </a>

      </div>

    </div>

  </section>

  <!-- ================================================= -->
  <!-- WHY CHOOSE LAYER FORGE -->
  <!-- ================================================= -->

  <section class="bg-slate-900 py-20">

    <div class="mx-auto max-w-7xl px-6">

      <div class="text-center">

        <h2 class="text-4xl font-bold text-white">
          Why Choose Layer Forge?
        </h2>

        <p class="mx-auto mt-5 max-w-3xl text-lg text-slate-300">
          We combine modern manufacturing technology with exceptional customer
          service to help individuals, makers and businesses bring their ideas
          to life.
        </p>

      </div>

      <div class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-4">

        <div class="rounded-2xl bg-slate-800 p-8 text-center">

          <h3 class="text-xl font-semibold text-white">
            High Quality
          </h3>

          <p class="mt-4 text-slate-300">
            Professional equipment and premium materials ensure consistent,
            high-quality results.
          </p>

        </div>

        <div class="rounded-2xl bg-slate-800 p-8 text-center">

          <h3 class="text-xl font-semibold text-white">
            Fast Turnaround
          </h3>

          <p class="mt-4 text-slate-300">
            Efficient production with clear communication throughout your
            project.
          </p>

        </div>

        <div class="rounded-2xl bg-slate-800 p-8 text-center">

          <h3 class="text-xl font-semibold text-white">
            Competitive Pricing
          </h3>

          <p class="mt-4 text-slate-300">
            Fair, transparent pricing with free no-obligation quotations.
          </p>

        </div>

        <div class="rounded-2xl bg-slate-800 p-8 text-center">

          <h3 class="text-xl font-semibold text-white">
            Canada Wide Service
          </h3>

          <p class="mt-4 text-slate-300">
            Local pickup, local delivery and shipping available across Canada.
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- ================================================= -->
  <!-- CALL TO ACTION -->
  <!-- ================================================= -->

  <section class="bg-yellow-400 py-20">

    <div class="mx-auto max-w-5xl px-6 text-center">

      <h2 class="text-5xl font-bold text-slate-900">
        Ready to Start Your Project?
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl leading-8 text-slate-800">
        Whether you need a prototype, custom gift, promotional product or
        production parts, we're ready to help bring your ideas to life.
      </p>

      <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">

        <a
          href="/quote"
          class="rounded-xl bg-slate-900 px-8 py-2 text-lg font-semibold text-white transition hover:bg-slate-800"
        >
          Request a Quote
        </a>

        <a
          href="/contact"
          class="rounded-xl border-2 border-slate-900 px-8 py-2 text-lg font-semibold text-slate-900 transition hover:bg-slate-900 hover:text-white"
        >
          Contact Us
        </a>

      </div>

    </div>

  </section>

</section>

</MainLayout>
