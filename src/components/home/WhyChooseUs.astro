---
const strengths = [
  {
    title: "Made for Your Project",
    description:
      "Thoughtful recommendations and custom production built around your design, material, and end use.",
    icon: "custom",
  },
  {
    title: "Reliable Turnaround",
    description:
      "Clear expectations, efficient production, and dependable timelines from approval to completion.",
    icon: "turnaround",
  },
  {
    title: "Precision at Every Step",
    description:
      "Professional equipment, controlled processes, and careful inspection ensure a refined result.",
    icon: "precision",
  },
  {
    title: "Service That Stays Personal",
    description:
      "Work directly with a local maker who understands your project and keeps communication simple.",
    icon: "service",
  },
];
---

<section class="relative overflow-hidden bg-slate-50 py-24 sm:py-28">
  <div
    class="pointer-events-none absolute -right-24 top-10 h-72 w-72 rounded-full bg-yellow-300/20 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.28em] text-yellow-600">
          Why Layer Forge
        </p>
        <h2 class="mt-4 max-w-xl text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">
          Built with care.<br />Delivered with confidence.
        </h2>
      </div>

      <div class="border-l-4 border-yellow-400 pl-6 lg:mb-1">
        <p class="max-w-2xl text-lg leading-8 text-slate-600">
          Modern equipment is only part of the process. Every Layer Forge project
          combines practical guidance, controlled production, and a careful final
          inspection—so the finished piece is ready to impress.
        </p>
      </div>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        strengths.map((strength) => (
          <article class="group rounded-3xl border border-slate-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-yellow-300 hover:shadow-xl hover:shadow-slate-900/10">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-yellow-400 text-slate-950 transition-transform duration-300 group-hover:scale-105">
              {strength.icon === "custom" && (
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 7h10" />
                  <path d="M18 7h2" />
                  <path d="M4 17h2" />
                  <path d="M10 17h10" />
                  <circle cx="16" cy="7" r="2" />
                  <circle cx="8" cy="17" r="2" />
                </svg>
              )}
              {strength.icon === "turnaround" && (
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="8" />
                  <path d="M12 8v4l3 2" />
                  <path d="M7 3 4 6" />
                  <path d="m17 3 3 3" />
                </svg>
              )}
              {strength.icon === "precision" && (
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="7" />
                  <circle cx="12" cy="12" r="2.5" />
                  <path d="M12 2v3" />
                  <path d="M12 19v3" />
                  <path d="M2 12h3" />
                  <path d="M19 12h3" />
                </svg>
              )}
              {strength.icon === "service" && (
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 18.5H5a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7l-4 3v-3Z" />
                  <path d="M8 10h8" />
                  <path d="M8 14h5" />
                </svg>
              )}
            </div>

            <h3 class="mt-7 text-xl font-bold tracking-tight text-slate-950">
              {strength.title}
            </h3>
            <p class="mt-3 leading-7 text-slate-600">
              {strength.description}
            </p>
          </article>
        ))
      }
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-slate-200 pt-7 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-semibold text-slate-900">
        One point of contact—from first question to finished order.
      </p>
      <p>Made locally in Surrey, British Columbia.</p>
    </div>
  </div>
</section>
