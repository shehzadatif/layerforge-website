---
interface Props {
  title: string;
  description: string;
  image: string;
  slug: string;
}

const { title, description, image, slug } = Astro.props;
---

<a
  href={`/solutions/${slug}`}
  class="group overflow-hidden rounded-2xl bg-white shadow-lg transition duration-300 hover:-translate-y-2 hover:shadow-2xl"
>
  <div class="overflow-hidden">
    <img
      src={image}
      alt={title}
      class="h-64 w-full object-cover transition duration-500 group-hover:scale-105"
    />
  </div>

  <div class="p-6">
    <h3 class="text-2xl font-bold text-slate-900">
      {title}
    </h3>

    <p class="mt-4 text-slate-600">
      {description}
    </p>

    <span
      class="mt-6 inline-block font-semibold text-yellow-500 transition group-hover:translate-x-1"
    >
      Learn More →
    </span>
  </div>
</a>