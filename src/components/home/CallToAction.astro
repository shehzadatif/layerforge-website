---
import Button from "../ui/Button.astro";
---

<section class="bg-yellow-400 py-24">

  <div class="mx-auto max-w-5xl px-6 text-center">

    <h2 class="text-5xl font-bold text-black">
      Ready to Bring Your Idea to Life?
    </h2>

    <p class="mx-auto mt-6 max-w-3xl text-xl text-slate-800">
      Whether you need a one-of-a-kind part, personalized gift,
      workshop accessory, or custom promotional product,
      we're here to help turn your ideas into reality.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-4">

      <Button
        href="/contact"
        text="Request a Quote"
        variant="secondary"
      />

     
    </div>

  </div>

</section>