---
import Button from '../ui/Button.astro';
---

<section class="bg-slate-950 text-white">

  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-24 lg:grid-cols-2">

    <div>

      <p class="font-semibold uppercase tracking-[0.3em] text-yellow-400">
        LAYER FORGE
      </p>

    <h1 class="text-6xl font-bold">
Custom Manufacturing &
Personalization Solutions
</h1>
      <p class="mt-8 text-xl leading-8 text-slate-300">
       From functional 3D printed parts and workshop accessories to laser engraving, UV printing, and personalized gifts, Layer Forge transforms your ideas into high-quality custom creations.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">

        <Button
          href="/solutions"
          text="Explore Solutions"
        />

        <Button
          href="/quote"
          text="Request a Quote"
          variant="secondary"
        />

      </div>

    </div>

    <div>

      <img
        src="/images/products/3d-printing.png"
        alt="Layer Forge"
        class="rounded-3xl shadow-2xl"
      />

    </div>

  </div>

</section>