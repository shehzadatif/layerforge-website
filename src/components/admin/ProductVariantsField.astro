---
type Variant = {
  id?: string | number | null;
  option_value?: string | null;
  price?: number | string | null;
  sku?: string | null;
  image_url?: string | null;
};

interface Props {
  variants?: Variant[] | null;
  imageBaseUrl?: string;
}

const variants = Astro.props.variants ?? [];
const imageBaseUrl = Astro.props.imageBaseUrl ?? "";

function getImageUrl(path?: string | null) {
  if (!path) return "";

  return path.startsWith("http://") || path.startsWith("https://")
    ? path
    : `${imageBaseUrl}${path}`;
}
---

<section
  class="rounded-xl border border-slate-200 bg-slate-50 p-6"
  data-product-variants
>
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h2 class="text-xl font-bold text-slate-900">Product Variants</h2>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-500">
        Add optional models, sizes, or configurations. Each variant uses its own
        CAD base price; the selected material markup is applied afterward.
      </p>
    </div>

    <button
      type="button"
      class="rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700"
      data-add-variant
    >
      + Add Variant
    </button>
  </div>

  <div class="mt-6 space-y-4" data-variant-list>
    {
      variants.map((variant) => (
        <div
          class="rounded-xl border bg-white p-4"
          data-variant-row
        >
          <input
            type="hidden"
            name="variant_id"
            value={variant.id == null ? "" : String(variant.id)}
          />

          <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_10rem_minmax(0,0.8fr)_auto] md:items-end">
            <label class="block">
              <span class="mb-2 block text-sm font-semibold">Variant Name</span>
              <input
                name="variant_name"
                value={variant.option_value ?? ""}
                placeholder="e.g. Battery Mount"
                maxlength="120"
                required
                class="w-full rounded-lg border p-3"
              />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-semibold">Price (CAD)</span>
              <input
                type="number"
                name="variant_price"
                value={variant.price ?? ""}
                min="0.01"
                step="0.01"
                required
                class="w-full rounded-lg border p-3"
              />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-semibold">SKU (Optional)</span>
              <input
                name="variant_sku"
                value={variant.sku ?? ""}
                maxlength="80"
                placeholder="LF-M18-BAT"
                class="w-full rounded-lg border p-3"
              />
            </label>

            <button
              type="button"
              class="rounded-lg border border-red-200 px-4 py-3 font-semibold text-red-700 hover:bg-red-50"
              data-remove-variant
            >
              Remove
            </button>
          </div>

          <div class="mt-4 grid gap-4 border-t border-slate-100 pt-4 sm:grid-cols-[6rem_minmax(0,1fr)] sm:items-center">
            <div
              class="flex h-24 w-24 items-center justify-center overflow-hidden rounded-lg border bg-slate-50 text-center text-xs text-slate-400"
              data-variant-image-preview
            >
              {variant.image_url ? (
                <img
                  src={getImageUrl(variant.image_url)}
                  alt={`${variant.option_value ?? "Variant"} preview`}
                  class="h-full w-full object-contain"
                />
              ) : (
                <span>No image</span>
              )}
            </div>

            <label class="block">
              <span class="mb-2 block text-sm font-semibold">
                Variant Image (Optional)
              </span>
              <input
                type="file"
                name="variant_image"
                accept="image/jpeg,image/png,image/webp,image/gif"
                class="block w-full rounded-lg border bg-white p-3 text-sm"
                data-variant-image-input
              />
              <span class="mt-2 block text-xs leading-5 text-slate-500">
                Uploading a new image replaces the current one. JPG, PNG, WebP,
                or GIF up to 10 MB.
              </span>
            </label>
          </div>
        </div>
      ))
    }
  </div>

  <p
    class:list={[
      "mt-6 rounded-lg border border-dashed p-4 text-center text-sm text-slate-500",
      variants.length > 0 && "hidden",
    ]}
    data-variant-empty
  >
    No variants added. Customers will order the base model and base price.
  </p>

  <template data-variant-template>
    <div
      class="rounded-xl border bg-white p-4"
      data-variant-row
    >
      <input type="hidden" name="variant_id" value="" />

      <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_10rem_minmax(0,0.8fr)_auto] md:items-end">
        <label class="block">
          <span class="mb-2 block text-sm font-semibold">Variant Name</span>
          <input
            name="variant_name"
            placeholder="e.g. Battery Mount"
            maxlength="120"
            required
            class="w-full rounded-lg border p-3"
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-semibold">Price (CAD)</span>
          <input
            type="number"
            name="variant_price"
            min="0.01"
            step="0.01"
            required
            class="w-full rounded-lg border p-3"
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-semibold">SKU (Optional)</span>
          <input
            name="variant_sku"
            maxlength="80"
            placeholder="LF-M18-BAT"
            class="w-full rounded-lg border p-3"
          />
        </label>

        <button
          type="button"
          class="rounded-lg border border-red-200 px-4 py-3 font-semibold text-red-700 hover:bg-red-50"
          data-remove-variant
        >
          Remove
        </button>
      </div>

      <div class="mt-4 grid gap-4 border-t border-slate-100 pt-4 sm:grid-cols-[6rem_minmax(0,1fr)] sm:items-center">
        <div
          class="flex h-24 w-24 items-center justify-center overflow-hidden rounded-lg border bg-slate-50 text-center text-xs text-slate-400"
          data-variant-image-preview
        >
          <span>No image</span>
        </div>

        <label class="block">
          <span class="mb-2 block text-sm font-semibold">
            Variant Image (Optional)
          </span>
          <input
            type="file"
            name="variant_image"
            accept="image/jpeg,image/png,image/webp,image/gif"
            class="block w-full rounded-lg border bg-white p-3 text-sm"
            data-variant-image-input
          />
          <span class="mt-2 block text-xs leading-5 text-slate-500">
            JPG, PNG, WebP, or GIF up to 10 MB.
          </span>
        </label>
      </div>
    </div>
  </template>
</section>

<script>
  function initializeVariantFields(root: HTMLElement) {
    if (root.dataset.initialized === "true") return;

    root.dataset.initialized = "true";

    const list = root.querySelector<HTMLElement>("[data-variant-list]");
    const template = root.querySelector<HTMLTemplateElement>(
      "[data-variant-template]",
    );
    const addButton = root.querySelector<HTMLButtonElement>(
      "[data-add-variant]",
    );
    const emptyState = root.querySelector<HTMLElement>("[data-variant-empty]");

    if (!list || !template || !addButton || !emptyState) return;

    const updateEmptyState = () => {
      emptyState.classList.toggle(
        "hidden",
        Boolean(list.querySelector("[data-variant-row]")),
      );
    };

    const connectRemoveButton = (row: Element) => {
      row
        .querySelector<HTMLButtonElement>("[data-remove-variant]")
        ?.addEventListener("click", () => {
          row.remove();
          updateEmptyState();
        });
    };

    const connectImagePreview = (row: Element) => {
      const input = row.querySelector<HTMLInputElement>(
        "[data-variant-image-input]",
      );
      const preview = row.querySelector<HTMLElement>(
        "[data-variant-image-preview]",
      );

      if (!input || !preview) return;

      input.addEventListener("change", () => {
        const previousPreviewUrl = preview.dataset.previewUrl;

        if (previousPreviewUrl) {
          URL.revokeObjectURL(previousPreviewUrl);
          delete preview.dataset.previewUrl;
        }

        const file = input.files?.[0];

        if (!file) return;

        const previewUrl = URL.createObjectURL(file);
        preview.dataset.previewUrl = previewUrl;
        preview.replaceChildren();

        const image = document.createElement("img");
        image.src = previewUrl;
        image.alt = "Selected variant image preview";
        image.className = "h-full w-full object-contain";
        preview.appendChild(image);
      });
    };

    list.querySelectorAll("[data-variant-row]").forEach((row) => {
      connectRemoveButton(row);
      connectImagePreview(row);
    });

    addButton.addEventListener("click", () => {
      const fragment = template.content.cloneNode(true) as DocumentFragment;
      const row = fragment.querySelector("[data-variant-row]");

      if (!row) return;

      connectRemoveButton(row);
      connectImagePreview(row);
      list.appendChild(fragment);
      updateEmptyState();

      row.querySelector<HTMLInputElement>("[name='variant_name']")?.focus();
    });

    updateEmptyState();
  }

  document
    .querySelectorAll<HTMLElement>("[data-product-variants]")
    .forEach(initializeVariantFields);
</script>
