---
interface Props {
  title: string;
  value: number | string;
  color?: string;
}

const {
  title,
  value,
  color = "text-slate-900",
} = Astro.props;
---

<div class="rounded-2xl bg-white p-6 shadow-sm border border-slate-200">

    <p class="text-sm text-slate-500">
        {title}
    </p>

    <h2 class={`mt-3 text-4xl font-bold ${color}`}>
        {value}
    </h2>

</div>