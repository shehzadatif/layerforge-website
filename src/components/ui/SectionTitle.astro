---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  center?: boolean;
}

const {
  eyebrow,
  title,
  description,
  center = true
} = Astro.props;
---

<div class={center ? "text-center" : ""}>

  {eyebrow && (
    <p class="font-semibold uppercase tracking-[0.3em] text-yellow-400">
      {eyebrow}
    </p>
  )}

  <h2 class="mt-3 text-4xl font-bold md:text-5xl text-gray-900">
    {title}
  </h2>

  {description && (
    <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-gray-600">
      {description}
    </p>
  )}

</div>