---
import "../styles/global.css";
import Navbar from "../components/layout/Navbar.astro";
import AppToaster from "../components/layout/AppToaster";

interface Props {
  title?: string;
}

const {
  title = "Layer Forge",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body>
<AppToaster client:load />
    <Navbar />

    <main>
      <slot />
    </main>

  </body>
</html>