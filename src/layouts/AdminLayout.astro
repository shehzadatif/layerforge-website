---
import "../styles/global.css";

const {
  title = "Layer Forge Admin",
  active = "dashboard",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>

<body class="bg-slate-100">

<div class="flex min-h-screen">

  <aside class="w-64 bg-slate-900 text-white">

    <div class="border-b border-slate-700 p-6">

      <h1 class="text-2xl font-bold text-yellow-400">
        Layer Forge
      </h1>

      <p class="mt-1 text-sm text-slate-400">
        Admin Panel
      </p>

    </div>

    <nav class="space-y-2 p-4">

      <a
        href="/admin"
        class={`block rounded-lg px-4 py-3 transition ${
          active === "dashboard"
            ? "bg-yellow-400 text-slate-900 font-semibold"
            : "text-white hover:bg-slate-700"
        }`}
      >
        📊 Dashboard
      </a>

      <a
        href="/admin/quotes"
        class={`block rounded-lg px-4 py-3 transition ${
          active === "quotes"
            ? "bg-yellow-400 text-slate-900 font-semibold"
            : "text-white hover:bg-slate-700"
        }`}
      >
        📋 Quotes
      </a>

      <a
  href="/admin/orders"
  class={`block rounded-lg px-4 py-3 transition ${
    active === "orders"
      ? "bg-yellow-400 text-slate-900 font-semibold"
      : "text-white hover:bg-slate-700"
  }`}
>
  🛒 Orders
</a>

<a
  href="/admin/manufacturing"
  class={`block rounded-lg px-4 py-3 transition ${
    active === "manufacturing"
      ? "bg-yellow-400 text-slate-900 font-semibold"
      : "text-white hover:bg-slate-700"
  }`}
>
  🏭 Manufacturing
</a>

      <a href="/admin/products" class="block rounded-lg px-4 py-3 hover:bg-slate-700">
        📦 Products
      </a>

     <a
  href="/admin/materials"
  class={`flex items-center gap-3 rounded-lg px-4 py-3 transition ${
    active === "materials"
      ? "bg-yellow-400 font-semibold text-slate-900"
      : "text-white hover:bg-slate-800"
  }`}
>
  🧱 Materials
</a>

      <a href="/admin/customers" class="block rounded-lg px-4 py-3 hover:bg-slate-700">
        👥 Customers
      </a>
      
      <a href="/admin/settings" class="block rounded-lg px-4 py-3 hover:bg-slate-700">
        ⚙️ Settings
      </a>

    </nav>

  </aside>

  <main class="flex-1 p-10">
    <slot />
  </main>

</div>

</body>
</html>