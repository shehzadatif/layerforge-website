---
interface Props {
  title: string;
  category: string;
  service: string;
  material: string;
  image: string;
  description: string;
}

const {
  title,
  category,
  service,
  material,
  image,
  description
} = Astro.props;
---

<div
  class="group overflow-hidden rounded-2xl bg-white shadow-lg transition duration-300 hover:-translate-y-2 hover:shadow-2xl"
>

  <div class="overflow-hidden">
    <img
      src={image}
      alt={title}
      class="h-72 w-full object-cover transition duration-500 group-hover:scale-105"
    />
  </div>

  <div class="p-6">

    <span class="rounded-full bg-yellow-100 px-3 py-1 text-sm font-semibold text-yellow-700">
      {category}
    </span>

    <h3 class="mt-4 text-2xl font-bold text-slate-900">
      {title}
    </h3>

    <p class="mt-4 text-slate-600">
      {description}
    </p>

    <div class="mt-6 flex gap-2 flex-wrap">

      <span class="rounded-full bg-slate-100 px-3 py-1 text-sm">
        {service}
      </span>

      <span class="rounded-full bg-slate-100 px-3 py-1 text-sm">
        {material}
      </span>

    </div>

  </div>

</div>