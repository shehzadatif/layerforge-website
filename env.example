# -------------------------------------------------------------------
# Layer Forge
# Environment Variables
# Copy this file to .env and fill in your production values.
# -------------------------------------------------------------------

# -------------------------------------------------
# Supabase
# -------------------------------------------------

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# -------------------------------------------------
# Stripe
# -------------------------------------------------

STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx

# -------------------------------------------------
# Email
# -------------------------------------------------

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

FROM_EMAIL=noreply@yourdomain.com
QUOTE_FROM_EMAIL="Layer Forge <quotes@yourdomain.com>"
QUOTE_TO_EMAIL=quotes@yourdomain.com
QUOTE_TO_EMAIL=owner@yourdomain.com
ORDER_FROM_EMAIL="Layer Forge <orders@yourdomain.com>"
CONTACT_FROM_EMAIL="Layer Forge <noreply@yourdomain.com>"
CONTACT_TO_EMAIL=support@yourdomain.com

# -------------------------------------------------
# Cloudflare Turnstile (recommended for production)
# -------------------------------------------------

PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# -------------------------------------------------
# Application
# -------------------------------------------------

PUBLIC_SITE_URL=https://yourdomain.com

NODE_ENV=production
